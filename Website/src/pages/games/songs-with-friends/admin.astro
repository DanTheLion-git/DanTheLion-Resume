---
import '../../../styles/global.css';
import '../../../styles/games.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Songs with Friends — Card Generator</title>

  <style>
    /* ── Screen-only styles ─────────────────────────────────────────────────── */

    /* ── Admin-specific screen styles ───────────────────────────────────── */
    .track-row {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.6rem 0.75rem;
      border-radius: var(--g-radius-sm);
      background: var(--g-surface);
      border: 1px solid var(--g-border);
      cursor: pointer;
      transition: border-color 0.15s;
    }

    .track-row:hover { border-color: var(--g-accent); }
    .track-row.selected { border-color: var(--g-green); }

    .track-row input[type="checkbox"] {
      accent-color: var(--g-green);
      width: 1rem;
      height: 1rem;
      flex-shrink: 0;
    }

    .track-thumb {
      width: 40px;
      height: 40px;
      border-radius: 4px;
      object-fit: cover;
      flex-shrink: 0;
      background: var(--g-surface2);
    }

    .track-info { flex: 1; min-width: 0; }
    .track-name { font-weight: 600; font-size: 0.9rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .track-meta { font-size: 0.75rem; color: var(--g-muted); }

    .track-year {
      font-size: 0.8rem;
      font-weight: 700;
      color: var(--g-accent2);
      flex-shrink: 0;
    }

    .print-preview-section {
      background: var(--g-surface);
      border: 1px solid var(--g-border);
      border-radius: var(--g-radius);
      padding: 1rem;
    }

    .print-preview-section h3 {
      font-size: 0.9rem;
      font-weight: 700;
      color: var(--g-muted);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 0.75rem;
    }

    .spinner {
      display: inline-block;
      width: 16px;
      height: 16px;
      border: 2px solid var(--g-border);
      border-top-color: var(--g-accent);
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
      vertical-align: middle;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    /* ── Playlist picker grid ───────────────────────────────────────────── */
    .playlist-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
      gap: 0.75rem;
      width: 100%;
    }
    .playlist-tile {
      background: var(--g-surface);
      border: 1px solid var(--g-border);
      border-radius: var(--g-radius-sm);
      cursor: pointer;
      overflow: hidden;
      transition: border-color 150ms, transform 150ms;
      display: flex;
      flex-direction: column;
      text-align: left;
      padding: 0;
    }
    .playlist-tile:hover {
      border-color: var(--g-accent2);
      transform: translateY(-2px);
    }
    .playlist-tile img {
      width: 100%;
      height: 0;
      padding-bottom: 100%; /* forces perfect 1:1 square */
      object-fit: cover;
      display: block;
      background: var(--g-surface2);
    }
    .playlist-tile .pl-art-placeholder {
      width: 100%;
      aspect-ratio: 1 / 1;
      background: var(--g-surface2);
      font-size: 2rem;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .playlist-tile-info  { padding: 0.5rem 0.6rem; }
    .playlist-tile-name  {
      font-size: 0.82rem; font-weight: 700;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      color: var(--g-text);
    }
    .playlist-tile-count { font-size: 0.7rem; color: var(--g-muted); margin-top: 0.15rem; }
    .pl-private { opacity: 0.5; cursor: default; }
    .pl-private:hover { border-color: var(--g-border); transform: none; }

    /* ── Review section styles ──────────────────────────────────────────── */
    .review-group {
      background: var(--g-surface);
      border: 1px solid var(--g-border);
      border-radius: var(--g-radius-sm);
      padding: 0.75rem;
      display: flex; flex-direction: column; gap: 0.5rem;
    }
    .review-group.duplicate { border-left: 3px solid #e67e22; }
    .review-group.remaster  { border-left: 3px solid #3498db; }

    .review-group-header {
      display: flex; align-items: center; gap: 0.5rem;
      font-size: 0.82rem; font-weight: 700;
    }
    .review-badge {
      font-size: 0.65rem; font-weight: 700; padding: 0.15em 0.45em;
      border-radius: 3px; text-transform: uppercase; letter-spacing: 0.04em;
    }
    .review-badge.dup  { background: #fdebd0; color: #a0522d; }
    .review-badge.rem  { background: #d6eaf8; color: #21618c; }

    .review-option {
      display: flex; align-items: center; gap: 0.6rem;
      padding: 0.5rem 0.6rem;
      border-radius: var(--g-radius-sm);
      background: var(--g-bg);
      border: 1px solid var(--g-border);
      cursor: pointer;
      transition: border-color 0.15s;
    }
    .review-option:hover { border-color: var(--g-accent); }
    .review-option.chosen { border-color: var(--g-green); background: rgba(46,204,113,0.06); }

    .review-option input[type="radio"] {
      accent-color: var(--g-green); flex-shrink: 0;
    }
    .review-option-info { flex: 1; min-width: 0; }
    .review-option-name { font-size: 0.85rem; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .review-option-meta { font-size: 0.72rem; color: var(--g-muted); }
    .review-option-year {
      font-size: 0.85rem; font-weight: 700; flex-shrink: 0;
      color: var(--g-accent2);
    }

    .review-summary {
      display: flex; gap: 0.75rem; flex-wrap: wrap;
      font-size: 0.82rem; color: var(--g-muted);
    }
    .review-summary span { display: flex; align-items: center; gap: 0.3rem; }
  </style>
</head>

<body class="game-page">

  <header class="site-header no-print">
    <div class="container">
      <a href="/" class="logo">The Lions Alliance</a>
      <nav class="nav">
        <a href="/games/">Games</a>
        <a href="/resume/">Resume</a>
          <a href="/planner/">Planner</a>
        <button id="btn-logout" class="g-btn outline small hidden" style="width:auto;font-size:0.8rem;">Disconnect</button>
        <button id="theme-toggle" class="theme-toggle" aria-label="Toggle colour scheme" title="Toggle light / dark mode">
          <svg class="theme-icon theme-icon--sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1"  x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22"  x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1"  y1="12" x2="3"  y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22"  y1="19.78" x2="5.64"  y2="18.36"/><line x1="18.36" y1="5.64"  x2="19.78" y2="4.22"/>
          </svg>
          <svg class="theme-icon theme-icon--moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
          </svg>
        </button>
      </nav>
    </div>
  </header>

  <!-- ══ NOT AUTHENTICATED ════════════════════════════════════════════════ -->
  <div id="screen-unauthed" class="game-content no-print hidden">
    <div style="text-align:center;">
      <div class="swf-logo">ADMIN</div>
      <p class="g-subtitle" style="margin-top:0.5rem;">Card Generator</p>
    </div>
    <div class="g-card" style="text-align:center;display:flex;flex-direction:column;gap:1rem;align-items:center;">
      <p style="font-size:0.9rem;color:var(--g-muted);">You need to connect Spotify first.</p>
      <a href="/games/songs-with-friends/" class="g-btn green" style="max-width:260px;">← Go to Songs with Friends</a>
    </div>
  </div>

  <!-- ══ MAIN ADMIN UI ════════════════════════════════════════════════════ -->
  <div id="screen-admin" class="game-content no-print hidden" style="gap:1.25rem;">

    <!-- Title -->
    <div style="text-align:center;width:100%;">
      <div class="swf-logo" style="font-size:1.8rem;">ADMIN</div>
      <p class="g-subtitle">Card Generator</p>
    </div>

    <!-- Playlist picker (shown on load) -->
    <div id="playlist-section" style="width:100%;display:flex;flex-direction:column;gap:1rem;">

      <!-- CSV Import panel — primary method (always works) -->
      <div class="g-card" style="gap:0.75rem;display:flex;flex-direction:column;">
        <div class="g-label" style="font-size:0.9rem;">📋 Import from CSV <span style="background:var(--g-accent);color:#fff;font-size:0.65rem;padding:0.1em 0.4em;border-radius:3px;margin-left:0.4rem;">RECOMMENDED</span></div>
        <p style="font-size:0.82rem;color:var(--g-muted);margin:0;line-height:1.7;">
          1. Go to <a href="https://exportify.net" target="_blank" rel="noopener" style="color:var(--g-accent2);">exportify.net</a> — log in with Spotify, click <strong>Export</strong> next to your Songs with Friends playlist.<br>
          2. Open the downloaded <code style="background:var(--g-surface2);padding:0.1em 0.3em;border-radius:3px;">.csv</code> file in a text editor or Excel → <strong>Select All → Copy</strong>.<br>
          3. Paste the contents into the field below and click <strong>Load Tracks from CSV</strong>.
        </p>
        <textarea id="csv-input" rows="5"
          placeholder="Paste Exportify CSV here (Spotify URI, Track Name, Artist Name(s), Album Release Date…)"
          style="width:100%;padding:0.7rem;background:var(--g-bg);border:1px solid var(--g-border);border-radius:var(--g-radius-sm);color:var(--g-text);font-size:0.78rem;font-family:monospace;resize:vertical;box-sizing:border-box;"></textarea>
        <div id="csv-error" class="g-alert error hidden"></div>
        <button id="btn-parse-csv" class="g-btn green">📋 Load Tracks from CSV</button>
      </div>

      <!-- Divider -->
      <div style="display:flex;align-items:center;gap:0.75rem;color:var(--g-muted);font-size:0.8rem;">
        <hr style="flex:1;border:none;border-top:1px solid var(--g-border);" />
        or load directly from Spotify (may require reconnect)
        <hr style="flex:1;border:none;border-top:1px solid var(--g-border);" />
      </div>

      <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:0.5rem;">
        <div class="g-label" style="font-size:0.9rem;">🎵 Your Playlists</div>
        <button id="btn-refresh-playlists" class="g-btn secondary small">&#8635; Refresh</button>
      </div>

      <!-- Loading / error states -->
      <div id="pl-loading" class="g-alert info hidden">
        <span class="spinner"></span>&nbsp; Loading your playlists…
      </div>
      <div id="pl-error" class="g-alert error hidden"></div>
      <button id="btn-reauth" class="g-btn outline small hidden" style="width:auto;align-self:flex-start;">
        &#128273; Reconnect Spotify (or <a href="https://www.spotify.com/account/apps" target="_blank" rel="noopener" style="color:inherit;text-decoration:underline;">remove app access first</a> if reconnect keeps failing)
      </button>

      <!-- Playlist grid -->
      <div id="playlist-grid" class="playlist-grid"></div>
    </div>

    <!-- Track list (hidden until a playlist is picked) -->
    <div id="track-section" class="hidden" style="width:100%;display:flex;flex-direction:column;gap:1rem;">

      <!-- Playlist header -->
      <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:0.5rem;">
        <div>
          <button id="btn-back-to-playlists" class="g-btn secondary small" style="width:auto;margin-bottom:0.4rem;">&#8592; All Playlists</button>
          <div id="playlist-name" class="g-label" style="font-size:0.9rem;color:var(--g-text);font-weight:700;"></div>
          <div id="playlist-meta" class="g-label"></div>
        </div>
        <div style="display:flex;gap:0.5rem;">
          <button id="btn-select-all"   class="g-btn secondary small">☑ All</button>
          <button id="btn-deselect-all" class="g-btn secondary small">☐ None</button>
        </div>
      </div>

      <!-- Track list -->
      <div id="track-list" style="display:flex;flex-direction:column;gap:0.4rem;max-height:50vh;overflow-y:auto;padding-right:0.25rem;"></div>

      <!-- Generate button -->
      <div style="display:flex;flex-direction:column;gap:0.5rem;">
        <div id="selection-count" class="g-label" style="text-align:center;"></div>
        <button id="btn-generate" class="g-btn primary" style="font-size:1rem;">
          🃏 Open Print Sheet ↗
        </button>
      </div>

    </div>

    <!-- Review section (shown when duplicates or remasters are detected) -->
    <div id="review-section" class="hidden" style="width:100%;display:flex;flex-direction:column;gap:1rem;">
      <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:0.5rem;">
        <div>
          <button id="btn-back-to-tracks" class="g-btn secondary small" style="width:auto;margin-bottom:0.4rem;">&#8592; Back to Track List</button>
          <div class="g-label" style="font-size:0.9rem;color:var(--g-text);font-weight:700;">Review &amp; Resolve</div>
          <div id="review-meta" class="g-label"></div>
        </div>
      </div>

      <div id="review-summary" class="review-summary"></div>

      <div class="g-alert info" style="font-size:0.82rem;">
        ℹ️ Resolve the issues below, then click <strong>Confirm &amp; Print</strong>.
        Duplicates: pick which version to keep. Remasters: choose which year to use.
      </div>

      <div id="review-list" style="display:flex;flex-direction:column;gap:0.75rem;max-height:55vh;overflow-y:auto;padding-right:0.25rem;"></div>

      <div style="display:flex;flex-direction:column;gap:0.5rem;">
        <div id="review-count" class="g-label" style="text-align:center;"></div>
        <button id="btn-confirm-print" class="g-btn primary" style="font-size:1rem;">
          ✅ Confirm &amp; Print ↗
        </button>
      </div>
    </div>

  </div><!-- /screen-admin -->


  <!-- ══ SCRIPTS ══════════════════════════════════════════════════════════ -->
  <script>
    import { isAuthenticated, getValidToken, logout, startSpotifyAuth, hasScope, grantedScopes } from '../../../lib/spotify';

    // ── Types ──────────────────────────────────────────────────────────────
    interface Track {
      id:       string;
      uri:      string;
      name:     string;
      artist:   string;
      year:     number;
      albumArt: string;
    }

    // ── State ──────────────────────────────────────────────────────────────
    let allTracks: Track[]       = [];
    let selectedIds: Set<string> = new Set();

    // ── DOM ────────────────────────────────────────────────────────────────
    const $  = (id: string) => document.getElementById(id)!;
    const show = (...ids: string[]) => ids.forEach(id => $( id).classList.remove('hidden'));
    const hide = (...ids: string[]) => ids.forEach(id => $( id).classList.add('hidden'));

    // ── Playlist parsing ───────────────────────────────────────────────────
    function parsePlaylistId(raw: string): string | null {
      const s = raw.trim();
      const uriMatch = s.match(/^spotify:playlist:([A-Za-z0-9]+)/);
      if (uriMatch) return uriMatch[1];
      const urlMatch = s.match(/open\.spotify\.com\/playlist\/([A-Za-z0-9]+)/);
      if (urlMatch) return urlMatch[1];
      if (/^[A-Za-z0-9]{22}$/.test(s)) return s;
      return null;
    }

    // ── Spotify API helpers ────────────────────────────────────────────────
    async function fetchPlaylistInfo(id: string, token: string) {
      const res = await fetch(`https://api.spotify.com/v1/playlists/${id}?fields=name,tracks.total`, {
        headers: { Authorization: `Bearer ${token}` },
      });
      if (!res.ok) throw new Error(`Could not load playlist (${res.status}). Is it public?`);
      return res.json();
    }

    function parseTrackItems(items: Array<{ track: null | Record<string, unknown> }>): Track[] {
      const result: Track[] = [];
      for (const item of items) {
        const t = item.track;
        if (!t || !t.id) continue;
        const artists = t.artists as Array<{ name: string }>;
        const album   = t.album   as { release_date: string; images: Array<{ url: string }> };
        result.push({
          id:       t.id      as string,
          uri:      `spotify:track:${t.id}`,
          name:     t.name    as string,
          artist:   artists.map(a => a.name).join(', '),
          year:     new Date(album.release_date).getFullYear(),
          albumArt: album.images[0]?.url ?? '',
        });
      }
      return result;
    }

    function spotifyError(status: number, detail: string): Error {
      if (status === 403) {
        const scopes = grantedScopes();
        return new Error(
          `Spotify returned 403 (Forbidden) — your access token is missing playlist permissions.\n\n` +
          `Stored scopes: ${scopes}\n\n` +
          `Fix: Go to spotify.com/account/apps → find this app → click "Remove Access" → ` +
          `then click "Reconnect Spotify" below to re-authorise with the full playlist scope.`
        );
      }
      return new Error(`Spotify error ${status}${detail ? ': ' + detail : ''}. Please try again.`);
    }

    async function fetchAllTracks(playlistId: string, token: string): Promise<Track[]> {
      const tracks: Track[] = [];
      let url: string | null =
        `https://api.spotify.com/v1/playlists/${playlistId}/tracks?limit=100`;

      while (url) {
        const res = await fetch(url, { headers: { Authorization: `Bearer ${token}` } });
        if (!res.ok) {
          const body = await res.json().catch(() => ({})) as { error?: { message?: string } };
          throw spotifyError(res.status, body?.error?.message ?? '');
        }
        const data = await res.json();
        tracks.push(...parseTrackItems(data.items ?? []));
        url = data.next ?? null;
      }

      if (tracks.length === 0) {
        throw new Error(
          'Playlist loaded but contains 0 playable tracks. ' +
          'Make sure the playlist has regular Spotify songs (not local files or podcasts).'
        );
      }

      return tracks;
    }

    // ── Track list rendering ───────────────────────────────────────────────
    function renderTrackList(tracks: Track[]) {
      const list = $('track-list');
      list.innerHTML = '';

      tracks.forEach((t) => {
        const row = document.createElement('div');
        row.className = 'track-row selected';
        row.dataset.id = t.id;

        row.innerHTML = `
          <input type="checkbox" checked data-id="${escHtml(t.id)}" />
          ${t.albumArt
            ? `<img class="track-thumb" src="${escHtml(t.albumArt)}" alt="" />`
            : `<div class="track-thumb" style="display:flex;align-items:center;justify-content:center;font-size:1.2rem;">🎵</div>`
          }
          <div class="track-info">
            <div class="track-name">${escHtml(t.name)}</div>
            <div class="track-meta">${escHtml(t.artist)}</div>
          </div>
          <div class="track-year">${t.year || '—'}</div>
        `;

        const cb = row.querySelector('input')!;
        selectedIds.add(t.id);

        const toggle = () => {
          if (cb.checked) { selectedIds.add(t.id); row.classList.add('selected'); }
          else            { selectedIds.delete(t.id); row.classList.remove('selected'); }
          updateSelectionCount();
        };

        cb.addEventListener('change', toggle);
        row.addEventListener('click', (e) => {
          if ((e.target as HTMLElement).tagName === 'INPUT') return;
          cb.checked = !cb.checked;
          toggle();
        });

        list.appendChild(row);
      });

      updateSelectionCount();
    }

    function updateSelectionCount() {
      $('selection-count').textContent = `${selectedIds.size} of ${allTracks.length} tracks selected`;
    }

    function escHtml(s: string): string {
      return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    // ── Remaster / duplicate detection ─────────────────────────────────────
    const REMASTER_RX = /[\s\-–—]+(\(?\s*)?(Remaster(ed)?|Anniversary|Deluxe|Expanded|Special)\s*(Edition|Version|Mix)?\s*\d{0,4}\s*\)?/gi;
    const REMASTER_TEST = /Remaster(ed)?|Anniversary\s*Edition|Deluxe\s*(Edition|Version)?|Expanded|Special\s*Edition/i;
    const FEAT_RX     = /\s*(\(feat\.?|ft\.?|featuring)\s+[^)]*\)?/gi;

    function normalizeName(name: string): string {
      return name
        .replace(REMASTER_RX, '')
        .replace(FEAT_RX, '')
        .replace(/\s*\(.*?(Mono|Stereo|Live|Acoustic|Radio\s*Edit|Single\s*Version).*?\)/gi, '')
        .trim()
        .toLowerCase();
    }

    function normalizeArtist(artist: string): string {
      return artist.split(',').map(a => a.trim().toLowerCase()).sort().join(', ');
    }

    function makeKey(name: string, artist: string): string {
      return `${normalizeName(name)}|||${normalizeArtist(artist)}`;
    }

    function isRemaster(name: string): boolean {
      return REMASTER_TEST.test(name);
    }

    interface DuplicateGroup {
      key: string;
      tracks: Track[];
    }

    interface RemasterIssue {
      track: Track;
      cleanName: string;
      originalYear: number | null;
      originalArtist: string | null;
      searchDone: boolean;
    }

    function findDuplicates(tracks: Track[]): DuplicateGroup[] {
      const groups = new Map<string, Track[]>();
      for (const t of tracks) {
        const key = makeKey(t.name, t.artist);
        const group = groups.get(key) ?? [];
        group.push(t);
        groups.set(key, group);
      }
      return Array.from(groups.values())
        .filter(g => g.length > 1)
        .map(tracks => ({ key: makeKey(tracks[0].name, tracks[0].artist), tracks }));
    }

    function findRemasters(tracks: Track[]): RemasterIssue[] {
      return tracks
        .filter(t => isRemaster(t.name))
        .map(t => ({
          track: t,
          cleanName: t.name.replace(REMASTER_RX, '').trim(),
          originalYear: null,
          originalArtist: null,
          searchDone: false,
        }));
    }

    async function searchOriginalYear(issue: RemasterIssue, token: string): Promise<void> {
      const artist = issue.track.artist.split(',')[0].trim();
      const q = `track:${issue.cleanName} artist:${artist}`;
      try {
        const res = await fetch(
          `https://api.spotify.com/v1/search?q=${encodeURIComponent(q)}&type=track&limit=20`,
          { headers: { Authorization: `Bearer ${token}` } }
        );
        if (!res.ok) { issue.searchDone = true; return; }
        const data = await res.json();
        const items = (data.tracks?.items ?? []) as Array<{
          name: string;
          artists: Array<{ name: string }>;
          album: { release_date: string };
        }>;

        // Find the earliest release that matches the normalized name
        let earliest: { year: number; artist: string } | null = null;
        const targetName = normalizeName(issue.cleanName);
        for (const item of items) {
          if (normalizeName(item.name) !== targetName) continue;
          const yr = new Date(item.album.release_date).getFullYear();
          if (!Number.isFinite(yr)) continue;
          if (!earliest || yr < earliest.year) {
            earliest = { year: yr, artist: item.artists.map(a => a.name).join(', ') };
          }
        }
        if (earliest && earliest.year < issue.track.year) {
          issue.originalYear = earliest.year;
          issue.originalArtist = earliest.artist;
        }
      } catch { /* search failed, leave as-is */ }
      issue.searchDone = true;
    }

    // ── Review state ──────────────────────────────────────────────────────
    // For duplicates: which track ID to keep per group
    let dupChoices  = new Map<string, string>(); // group key → chosen track id
    // For remasters: whether to use original year
    let remChoices  = new Map<string, 'original' | 'remaster'>(); // track id → choice

    function renderReview(dupes: DuplicateGroup[], remasters: RemasterIssue[], selected: Track[]) {
      const list = $('review-list');
      list.innerHTML = '';

      // Summary
      const summaryEl = $('review-summary');
      summaryEl.innerHTML = '';
      if (dupes.length > 0) {
        const s = document.createElement('span');
        s.innerHTML = `<span class="review-badge dup">DUP</span> ${dupes.length} duplicate group${dupes.length > 1 ? 's' : ''}`;
        summaryEl.appendChild(s);
      }
      if (remasters.length > 0) {
        const s = document.createElement('span');
        s.innerHTML = `<span class="review-badge rem">REM</span> ${remasters.length} remastered track${remasters.length > 1 ? 's' : ''}`;
        summaryEl.appendChild(s);
      }

      $('review-meta').textContent = `${selected.length} tracks selected — ${dupes.length + remasters.length} issue${(dupes.length + remasters.length) !== 1 ? 's' : ''} to review`;

      // Render duplicate groups
      for (const group of dupes) {
        const div = document.createElement('div');
        div.className = 'review-group duplicate';

        const header = document.createElement('div');
        header.className = 'review-group-header';
        header.innerHTML = `<span class="review-badge dup">DUPLICATE</span> "${escHtml(group.tracks[0].name)}" appears ${group.tracks.length} times — pick one to keep:`;
        div.appendChild(header);

        // Default: keep first
        if (!dupChoices.has(group.key)) dupChoices.set(group.key, group.tracks[0].id);

        for (const t of group.tracks) {
          const opt = document.createElement('label');
          const chosen = dupChoices.get(group.key) === t.id;
          opt.className = 'review-option' + (chosen ? ' chosen' : '');
          opt.innerHTML = `
            <input type="radio" name="dup-${escHtml(group.key)}" value="${escHtml(t.id)}" ${chosen ? 'checked' : ''} />
            <div class="review-option-info">
              <div class="review-option-name">${escHtml(t.name)}</div>
              <div class="review-option-meta">${escHtml(t.artist)} · ID: ${escHtml(t.id.slice(0,8))}…</div>
            </div>
            <div class="review-option-year">${t.year || '—'}</div>`;

          opt.querySelector('input')!.addEventListener('change', () => {
            dupChoices.set(group.key, t.id);
            // Update visuals
            div.querySelectorAll('.review-option').forEach(el => el.classList.remove('chosen'));
            opt.classList.add('chosen');
            updateReviewCount(dupes, remasters, selected);
          });
          div.appendChild(opt);
        }
        list.appendChild(div);
      }

      // Render remaster issues
      for (const rem of remasters) {
        const div = document.createElement('div');
        div.className = 'review-group remaster';

        const header = document.createElement('div');
        header.className = 'review-group-header';
        const yearDiff = rem.originalYear
          ? ` (original: ${rem.originalYear}, remaster: ${rem.track.year})`
          : ' (no earlier release found)';
        header.innerHTML = `<span class="review-badge rem">REMASTER</span> "${escHtml(rem.cleanName)}"${yearDiff}`;
        div.appendChild(header);

        if (rem.originalYear && rem.originalYear !== rem.track.year) {
          if (!remChoices.has(rem.track.id)) remChoices.set(rem.track.id, 'original');

          const optOrig = document.createElement('label');
          const origChosen = remChoices.get(rem.track.id) === 'original';
          optOrig.className = 'review-option' + (origChosen ? ' chosen' : '');
          optOrig.innerHTML = `
            <input type="radio" name="rem-${escHtml(rem.track.id)}" value="original" ${origChosen ? 'checked' : ''} />
            <div class="review-option-info">
              <div class="review-option-name">Use original release year</div>
              <div class="review-option-meta">${escHtml(rem.originalArtist ?? rem.track.artist)}</div>
            </div>
            <div class="review-option-year">${rem.originalYear}</div>`;

          const optRem = document.createElement('label');
          const remChosen = remChoices.get(rem.track.id) === 'remaster';
          optRem.className = 'review-option' + (remChosen ? ' chosen' : '');
          optRem.innerHTML = `
            <input type="radio" name="rem-${escHtml(rem.track.id)}" value="remaster" ${remChosen ? 'checked' : ''} />
            <div class="review-option-info">
              <div class="review-option-name">Keep remaster year</div>
              <div class="review-option-meta">${escHtml(rem.track.name)}</div>
            </div>
            <div class="review-option-year">${rem.track.year}</div>`;

          const updateChoice = () => {
            const val = (div.querySelector('input[type=radio]:checked') as HTMLInputElement)?.value as 'original' | 'remaster';
            remChoices.set(rem.track.id, val);
            div.querySelectorAll('.review-option').forEach(el => el.classList.remove('chosen'));
            (val === 'original' ? optOrig : optRem).classList.add('chosen');
          };
          optOrig.querySelector('input')!.addEventListener('change', updateChoice);
          optRem.querySelector('input')!.addEventListener('change', updateChoice);

          div.appendChild(optOrig);
          div.appendChild(optRem);
        } else {
          const note = document.createElement('div');
          note.style.cssText = 'font-size:0.82rem;color:var(--g-muted);padding:0.3rem 0;';
          note.textContent = rem.originalYear
            ? `Original and remaster have the same year (${rem.track.year}) — no action needed.`
            : `Could not find an earlier release. Will use ${rem.track.year}.`;
          div.appendChild(note);
        }

        list.appendChild(div);
      }

      updateReviewCount(dupes, remasters, selected);
    }

    function updateReviewCount(dupes: DuplicateGroup[], _remasters: RemasterIssue[], selected: Track[]) {
      // Count how many tracks will be removed as duplicates
      const removedIds = new Set<string>();
      for (const group of dupes) {
        const keepId = dupChoices.get(group.key);
        for (const t of group.tracks) {
          if (t.id !== keepId) removedIds.add(t.id);
        }
      }
      const finalCount = selected.filter(t => !removedIds.has(t.id)).length;
      $('review-count').textContent = `${finalCount} tracks after resolving (${removedIds.size} duplicate${removedIds.size !== 1 ? 's' : ''} removed)`;
    }

    function applyReviewChoices(selected: Track[], dupes: DuplicateGroup[], remasters: RemasterIssue[]): Track[] {
      // Remove duplicate losers
      const removedIds = new Set<string>();
      for (const group of dupes) {
        const keepId = dupChoices.get(group.key);
        for (const t of group.tracks) {
          if (t.id !== keepId) removedIds.add(t.id);
        }
      }
      let result = selected.filter(t => !removedIds.has(t.id));

      // Apply remaster year overrides
      for (const rem of remasters) {
        if (remChoices.get(rem.track.id) === 'original' && rem.originalYear) {
          const track = result.find(t => t.id === rem.track.id);
          if (track) track.year = rem.originalYear;
        }
      }
      return result;
    }

    // ── CSV Import (Exportify) ─────────────────────────────────────────────
    function parseCSVRow(line: string): string[] {
      const result: string[] = [];
      let cur = '', inQ = false;
      for (let i = 0; i < line.length; i++) {
        const c = line[i];
        if (c === '"') {
          if (inQ && line[i + 1] === '"') { cur += '"'; i++; }
          else inQ = !inQ;
        } else if (c === ',' && !inQ) {
          result.push(cur); cur = '';
        } else cur += c;
      }
      result.push(cur);
      return result;
    }

    function parseCSVToTracks(raw: string): Track[] {
      const lines = raw.replace(/\r\n/g, '\n').replace(/\r/g, '\n')
        .split('\n').map(l => l.trim()).filter(l => l.length > 0);
      if (lines.length < 2) throw new Error('Need a header row and at least one track row.');

      const headers = parseCSVRow(lines[0]).map(h => h.replace(/^"|"$/g, '').toLowerCase());

      const idx = (kws: string[]) => headers.findIndex(h => kws.some(k => h.includes(k)));
      const uriIdx    = idx(['spotify uri', 'uri', 'track uri']);
      const nameIdx   = idx(['track name', 'name', 'title', 'song']);
      const artistIdx = idx(['artist name', 'artist']);
      const yearIdx   = idx(['release date', 'album date', 'year', 'date']);

      if (nameIdx   === -1) throw new Error('Could not find "Track Name" column. Is this an Exportify CSV?');
      if (artistIdx === -1) throw new Error('Could not find "Artist Name(s)" column.');

      const tracks: Track[] = [];
      for (let i = 1; i < lines.length; i++) {
        const cols   = parseCSVRow(lines[i]).map(c => c.replace(/^"|"$/g, '').trim());
        const name   = cols[nameIdx]   ?? '';
        const artist = cols[artistIdx] ?? '';
        if (!name && !artist) continue;

        const rawUri  = uriIdx   >= 0 ? cols[uriIdx]  ?? '' : '';
        const rawYear = yearIdx  >= 0 ? cols[yearIdx] ?? '' : '';

        let year = 0;
        const ym = rawYear.match(/(\d{4})/);
        if (ym) year = parseInt(ym[1]);

        const uriMatch = rawUri.match(/spotify:track:([A-Za-z0-9]+)/);
        const id  = uriMatch ? uriMatch[1] : `csv-${i}`;
        const uri = uriMatch ? rawUri : `spotify:search:${encodeURIComponent(name + ' ' + artist)}`;
        tracks.push({ id, uri, name, artist, year, albumArt: '' });
      }
      if (tracks.length === 0) throw new Error('No valid tracks found in the pasted data.');
      return tracks;
    }

    $('btn-parse-csv').addEventListener('click', () => {
      hide('csv-error');
      const raw = ($('csv-input') as HTMLTextAreaElement).value;
      if (!raw.trim()) {
        $('csv-error').textContent = 'Please paste CSV data first.';
        show('csv-error');
        return;
      }
      try {
        const tracks = parseCSVToTracks(raw);
        allTracks   = tracks;
        selectedIds = new Set(tracks.map(t => t.id));
        $('playlist-name').textContent = 'CSV Import';
        $('playlist-meta').textContent = `${tracks.length} tracks loaded`;
        renderTrackList(tracks);
        hide('playlist-section');
        show('track-section');
      } catch (err) {
        $('csv-error').textContent = err instanceof Error ? err.message : String(err);
        show('csv-error');
      }
    });

    // ── Fetch user's playlists ─────────────────────────────────────────────
    interface SpotifyPlaylist {
      id: string;
      name: string;
      public: boolean | null;
      images: Array<{ url: string }>;
      tracks: { href: string; total: number } | null;
    }

    async function fetchUserPlaylists(token: string): Promise<SpotifyPlaylist[]> {
      const playlists: SpotifyPlaylist[] = [];
      let url: string | null = 'https://api.spotify.com/v1/me/playlists?limit=50';
      while (url) {
        const res = await fetch(url, { headers: { Authorization: `Bearer ${token}` } });
        if (!res.ok) throw new Error(`Could not load your Spotify playlists (${res.status})`);
        const data = await res.json();
        playlists.push(...(data.items as SpotifyPlaylist[]).filter(p => p && p.id));
        url = data.next as string | null;
      }
      return playlists;
    }

    function renderPlaylistGrid(playlists: SpotifyPlaylist[]) {
      const grid = $('playlist-grid');
      grid.innerHTML = '';
      if (playlists.length === 0) {
        grid.innerHTML = '<p style="color:var(--g-muted);font-size:0.88rem;">No playlists found.</p>';
        return;
      }

      // Info banner
      const info = document.createElement('p');
      info.style.cssText = 'font-size:0.8rem;color:var(--g-muted);margin:0 0 0.5rem;grid-column:1/-1;';
      info.textContent = '🔓 Click a public playlist to load it. 🔒 Private playlists need to be made public in Spotify first.';
      grid.appendChild(info);

      for (const pl of playlists) {
        const isPublic = pl.public === true;
        const btn = document.createElement('button');
        btn.className = 'playlist-tile' + (isPublic ? '' : ' pl-private');
        const artUrl = pl.images?.[0]?.url;
        const artHtml = artUrl
          ? `<div style="width:100%;aspect-ratio:1/1;overflow:hidden;background:var(--g-surface2)"><img src="${escHtml(artUrl)}" alt="" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;" /></div>`
          : `<div class="pl-art-placeholder">${isPublic ? '🎵' : '🔒'}</div>`;
        const total = pl.tracks?.total;
        btn.innerHTML = artHtml + `
          <div class="playlist-tile-info">
            <div class="playlist-tile-name" title="${escHtml(pl.name)}">${isPublic ? '' : '🔒 '}${escHtml(pl.name)}</div>
            <div class="playlist-tile-count">${total != null ? total + ' tracks' : isPublic ? 'public' : 'private'}</div>
          </div>`;

        if (isPublic) {
          btn.addEventListener('click', () => loadPlaylist(pl.id, pl.name, total ?? 0));
        } else {
          btn.title = 'Make this playlist public in Spotify to use it here';
          btn.addEventListener('click', () => {
            $('pl-error').textContent = `"${pl.name}" is private. In Spotify: open the playlist → ··· menu → Edit details → enable Public, then refresh.`;
            show('pl-error');
          });
        }
        grid.appendChild(btn);
      }
    }

    async function loadUserPlaylists() {
      hide('pl-error', 'btn-reauth');
      show('pl-loading');
      $('playlist-grid').innerHTML = '';
      try {
        const token = await getValidToken();
        if (!token) { logout(); location.href = '/games/songs-with-friends/'; return; }
        const playlists = await fetchUserPlaylists(token);
        renderPlaylistGrid(playlists);
      } catch (err) {
        $('pl-error').textContent = err instanceof Error ? err.message : String(err);
        show('pl-error');
      } finally {
        hide('pl-loading');
      }
    }

    async function loadPlaylist(playlistId: string, name: string, total: number) {
      hide('pl-error');
      $('playlist-name').textContent = name;
      $('playlist-meta').textContent = total ? `Loading ${total} tracks…` : 'Loading tracks…';
      hide('playlist-section');
      show('track-section');

      try {
        const token = await getValidToken();
        if (!token) { logout(); location.href = '/games/songs-with-friends/'; return; }

        const tracks = await fetchAllTracks(playlistId, token);
        allTracks = tracks;
        selectedIds = new Set(tracks.map(t => t.id));
        $('playlist-meta').textContent = `${tracks.length} tracks loaded`;
        renderTrackList(tracks);
      } catch (err) {
        $('playlist-meta').textContent = 'Failed to load tracks';
        hide('track-section');
        show('playlist-section');
        // Show full message (may contain newlines — use pre-wrap)
        const msg = err instanceof Error ? err.message : String(err);
        $('pl-error').style.whiteSpace = 'pre-wrap';
        $('pl-error').textContent = msg;
        show('pl-error', 'btn-reauth');
      }
    }

    // ── Select all / none ──────────────────────────────────────────────────
    $('btn-select-all').addEventListener('click', () => {
      document.querySelectorAll<HTMLInputElement>('#track-list input[type=checkbox]').forEach(cb => {
        cb.checked = true;
        const row = cb.closest('.track-row') as HTMLElement;
        row.classList.add('selected');
      });
      selectedIds = new Set(allTracks.map(t => t.id));
      updateSelectionCount();
    });

    $('btn-deselect-all').addEventListener('click', () => {
      document.querySelectorAll<HTMLInputElement>('#track-list input[type=checkbox]').forEach(cb => {
        cb.checked = false;
        (cb.closest('.track-row') as HTMLElement).classList.remove('selected');
      });
      selectedIds.clear();
      updateSelectionCount();
    });

    // ── Generate print sheet — with review step ───────────────────────────
    const SET_SIZE = 60;
    const MAX_TRACKS = 600;

    // Stash for the review → print flow
    let reviewDupes: DuplicateGroup[] = [];
    let reviewRemasters: RemasterIssue[] = [];
    let reviewSelected: Track[] = [];

    $('btn-generate').addEventListener('click', async () => {
      let selected = allTracks.filter(t => selectedIds.has(t.id));
      if (selected.length === 0) {
        alert('Please select at least one track.');
        return;
      }

      if (selected.length > MAX_TRACKS) {
        alert(`Maximum ${MAX_TRACKS} tracks supported. Only the first ${MAX_TRACKS} will be used.`);
        selected = selected.slice(0, MAX_TRACKS);
      }

      // Detect duplicates and remasters
      const dupes = findDuplicates(selected);
      const remasters = findRemasters(selected);

      // Look up original years for remasters (needs Spotify API)
      if (remasters.length > 0) {
        $('selection-count').textContent = `Checking ${remasters.length} remastered track${remasters.length !== 1 ? 's' : ''} for original releases…`;
        const token = await getValidToken();
        if (token) {
          for (const rem of remasters) {
            await searchOriginalYear(rem, token);
          }
        }
        // Filter out remasters where no year conflict was found
      }

      // If issues found, show the review screen
      const actionableRemasters = remasters.filter(r => r.originalYear && r.originalYear !== r.track.year);
      if (dupes.length > 0 || actionableRemasters.length > 0) {
        reviewDupes = dupes;
        reviewRemasters = remasters;
        reviewSelected = selected;
        dupChoices  = new Map();
        remChoices  = new Map();
        renderReview(dupes, actionableRemasters, selected);
        hide('track-section');
        show('review-section');
        return;
      }

      // No issues — go straight to print
      openPrintPage(selected);
    });

    function openPrintPage(tracks: Track[]) {
      const sets: Track[][] = [];
      for (let i = 0; i < tracks.length; i += SET_SIZE) {
        sets.push(tracks.slice(i, i + SET_SIZE));
      }

      const serialisedSets = sets.map(set =>
        set.map(t => ({ id: t.id, uri: t.uri, name: t.name, artist: t.artist, year: t.year }))
      );
      localStorage.setItem('swf_print_sets', JSON.stringify(serialisedSets));
      window.open('/games/songs-with-friends/print/?set=0', '_blank');
    }

    // ── Confirm & print from review ───────────────────────────────────────
    $('btn-confirm-print').addEventListener('click', () => {
      const actionableRemasters = reviewRemasters.filter(r => r.originalYear && r.originalYear !== r.track.year);
      const finalTracks = applyReviewChoices(reviewSelected, reviewDupes, actionableRemasters);
      if (finalTracks.length === 0) {
        alert('No tracks remaining after resolving duplicates.');
        return;
      }
      openPrintPage(finalTracks);
    });

    $('btn-back-to-tracks').addEventListener('click', () => {
      hide('review-section');
      show('track-section');
    });

    $('btn-back-to-playlists').addEventListener('click', () => {
      hide('track-section', 'preview-section', 'review-section');
      show('playlist-section');
    });

    $('btn-refresh-playlists').addEventListener('click', () => loadUserPlaylists());

    // ── Logout ─────────────────────────────────────────────────────────────
    $('btn-logout').addEventListener('click', () => { logout(); location.href = '/games/songs-with-friends/'; });

    // Re-auth with full scope — store return-to so callback lands back on admin
    $('btn-reauth').addEventListener('click', () => {
      sessionStorage.setItem('spotify_return_to', '/games/songs-with-friends/admin/');
      logout();
      startSpotifyAuth();
    });

    // ── Init ───────────────────────────────────────────────────────────────
    if (isAuthenticated()) {
      show('screen-admin', 'btn-logout');
      loadUserPlaylists();
    } else {
      show('screen-unauthed');
    }
  </script>

  <footer class="site-footer">
    <p>&copy; 2025 The Lions Alliance</p>
  </footer>

  <script is:inline>
    (function () {
      var btn  = document.getElementById('theme-toggle');
      var html = document.documentElement;
      if (!btn) return;
      btn.addEventListener('click', function () {
        var next = html.classList.contains('theme-light') ? 'dark' : 'light';
        html.className = 'theme-' + next;
        localStorage.setItem('lions-theme', next);
      });
    })();
  </script>
</body>
