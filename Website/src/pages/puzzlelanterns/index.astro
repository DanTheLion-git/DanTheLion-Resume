---
import "../../styles/homepage.css";
import "../../styles/puzzlelanterns.css";
const year = new Date().getFullYear();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Puzzle Lanterns &mdash; The Lions Alliance</title>
    <meta name="description" content="Puzzle Lanterns is an interactive experience concept in development by The Lions Alliance &mdash; built around story, exploration, and physical clues." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="tla-page">

    <!-- ── Navigation ─────────────────────────────────── -->
    <nav class="tla-nav" id="tla-nav">
      <div class="tla-nav__inner tla-container">
        <a href="/" class="tla-nav__logo">The Lions <span>Alliance</span></a>
        <ul class="tla-nav__links">
          <li><a href="#overview">Overview</a></li>
          <li><a href="#how-it-works">How It Works</a></li>
          <li><a href="#applications">Applications</a></li>
          <li><a href="#development">Development</a></li>
          <li><a href="#collaborate">Collaborate</a></li>
        </ul>
        <a href="/" class="tla-nav__cta">&larr; Back to Studio</a>
        <button class="tla-nav__hamburger" id="hamburger" aria-label="Toggle menu">
          <span></span><span></span><span></span>
        </button>
      </div>
      <div class="tla-nav__mobile" id="mobile-menu">
        <a href="#overview">Overview</a>
        <a href="#how-it-works">How It Works</a>
        <a href="#applications">Applications</a>
        <a href="#development">Development</a>
        <a href="#collaborate">Collaborate</a>
        <a href="/">&larr; Back to Studio</a>
      </div>
    </nav>

    <!-- ── Hero ───────────────────────────────────────── -->
    <section class="pl-hero" id="home">
      <div class="tla-container pl-hero__inner">
        <div class="pl-hero__text tla-fade">
          <div class="pl-hero__breadcrumb">
            <a href="/">The Lions Alliance</a>
            <span class="pl-hero__breadcrumb-sep">/</span>
            <span>Experiences Pillar</span>
          </div>
          <div class="pl-hero__badges">
            <span class="tla-badge tla-badge--dev">In Development</span>
            <span class="tla-badge tla-badge--future">Phase 2</span>
          </div>
          <h1 class="pl-hero__title">Puzzle <em>Lanterns</em></h1>
          <p class="pl-hero__subtitle">
            An interactive experience concept built around story, exploration, and physical clues. Part of The Lions Alliance&rsquo;s Experiences pillar.
          </p>
          <div class="pl-hero__ctas">
            <a href="#collaborate" class="tla-btn tla-btn--sage">Follow the project</a>
            <a href="/" class="tla-btn tla-btn--outline">&larr; The Lions Alliance</a>
          </div>
        </div>
        <div class="pl-hero__visual tla-fade tla-d1">
          <div class="pl-hero__placeholder">
            <span class="pl-hero__placeholder-icon">&#9670;</span>
          </div>
          <span class="pl-hero__placeholder-caption">Concept visual &mdash; in development</span>
        </div>
      </div>
    </section>

    <!-- ── The Concept ────────────────────────────────── -->
    <section class="pl-overview" id="overview">
      <div class="tla-container pl-overview__inner">
        <div class="pl-overview__text tla-fade">
          <span class="tla-overline">The concept</span>
          <h2 class="tla-section-header">Story-driven exploration through physical interaction</h2>
          <p>
            Puzzle Lanterns is an experience concept built around a simple idea: what if the environment itself tells the story? Rather than a screen or a guide, participants navigate through a world of physical lanterns, hidden clues, and responsive objects that reveal a narrative step by step.
          </p>
          <p>
            The concept is modular by design. The same interaction framework can power an intimate outdoor puzzle walk, a museum-style installation, or a venue-based storytelling experience.
          </p>
          <p>
            Puzzle Lanterns is currently in active development. We are refining the interaction model, building the first prototype routes, and exploring the formats this concept can grow into.
          </p>
          <div class="pl-tags">
            <span class="pl-tag">Physical interaction</span>
            <span class="pl-tag">Story progression</span>
            <span class="pl-tag">Group exploration</span>
            <span class="pl-tag">Modular format</span>
            <span class="pl-tag">Location-agnostic</span>
          </div>
        </div>
        <div class="pl-overview__visual tla-fade tla-d1">
          <div class="pl-overview__img">&#9670;</div>
        </div>
      </div>
    </section>

    <div class="tla-divider"></div>

    <!-- ── How It Works ───────────────────────────────── -->
    <section class="pl-steps-section" id="how-it-works">
      <div class="tla-container">
        <div class="tla-fade" style="text-align:center;">
          <span class="tla-overline">How it works</span>
          <h2 class="tla-section-header">The interaction model is designed to feel intuitive from the first step.</h2>
        </div>
        <div class="pl-steps">
          <div class="pl-step tla-fade">
            <div class="pl-step__number">I</div>
            <div class="pl-step__title">Find the first clue</div>
            <div class="pl-step__desc">A marker or location signals the beginning.</div>
          </div>
          <div class="pl-step tla-fade tla-d1">
            <div class="pl-step__number">II</div>
            <div class="pl-step__title">Interact with the lantern</div>
            <div class="pl-step__desc">Each lantern holds a piece of the narrative.</div>
          </div>
          <div class="pl-step tla-fade tla-d2">
            <div class="pl-step__number">III</div>
            <div class="pl-step__title">Uncover the next step</div>
            <div class="pl-step__desc">Each interaction reveals what comes next.</div>
          </div>
          <div class="pl-step tla-fade tla-d3">
            <div class="pl-step__number">IV</div>
            <div class="pl-step__title">Follow the story forward</div>
            <div class="pl-step__desc">The experience builds naturally to a final revelation.</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Future Applications ────────────────────────── -->
    <section class="pl-applications" id="applications">
      <div class="tla-container">
        <div class="tla-fade" style="text-align:center;">
          <span class="tla-overline">What it could become</span>
          <h2 class="tla-section-header">Three directions we are exploring.</h2>
        </div>
        <div class="pl-concept-grid">
          <div class="pl-concept-card tla-fade">
            <span class="pl-concept-card__icon">&#127939;</span>
            <div class="pl-concept-card__title">Puzzle Routes</div>
            <div class="pl-concept-card__desc">Outdoor puzzle walks through villages, parks, and heritage routes &mdash; self-guided adventures that blend storytelling with real-world exploration.</div>
          </div>
          <div class="pl-concept-card tla-fade tla-d1">
            <span class="pl-concept-card__icon">&#127979;</span>
            <div class="pl-concept-card__title">Interactive Installations</div>
            <div class="pl-concept-card__desc">For museums, heritage venues, campsites, and events &mdash; physical installations where visitors discover stories through objects and spaces.</div>
          </div>
          <div class="pl-concept-card tla-fade tla-d2">
            <span class="pl-concept-card__icon">&#128214;</span>
            <div class="pl-concept-card__title">Story-Driven Adventures</div>
            <div class="pl-concept-card__desc">Deeper narrative experiences with mystery, world-building, and history woven into the journey from start to finish.</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Development Status ─────────────────────────── -->
    <section class="pl-development" id="development">
      <div class="tla-container">
        <div class="tla-fade" style="text-align:center;">
          <span class="tla-overline">Progress</span>
          <h2 class="tla-section-header">Development in progress</h2>
        </div>
        <div class="pl-phase-grid">
          <div class="pl-phase-card pl-phase-card--done tla-fade">
            <div class="pl-phase-card__number">01</div>
            <div class="pl-phase-card__title">Concept &amp; Worldbuilding</div>
            <span class="pl-phase-card__badge">Complete</span>
          </div>
          <div class="pl-phase-card pl-phase-card--active tla-fade tla-d1">
            <div class="pl-phase-card__number">02</div>
            <div class="pl-phase-card__title">Interaction Design &amp; Prototyping</div>
            <span class="pl-phase-card__badge">In Progress</span>
          </div>
          <div class="pl-phase-card pl-phase-card--upcoming tla-fade tla-d2">
            <div class="pl-phase-card__number">03</div>
            <div class="pl-phase-card__title">Playtesting &amp; Route Design</div>
            <span class="pl-phase-card__badge">Upcoming</span>
          </div>
          <div class="pl-phase-card pl-phase-card--future tla-fade tla-d3">
            <div class="pl-phase-card__number">04</div>
            <div class="pl-phase-card__title">Live Experiences</div>
            <span class="pl-phase-card__badge">Future</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Our Thinking ───────────────────────────────── -->
    <section class="pl-philosophy">
      <div class="tla-container">
        <div class="tla-fade" style="text-align:center;">
          <span class="tla-overline">Our thinking</span>
          <h2 class="tla-section-header">Why we are building this</h2>
        </div>
        <div class="pl-philosophy__grid">
          <div class="pl-philosophy__card tla-fade">
            <span class="pl-philosophy__card-icon">&#9995;</span>
            <div class="pl-philosophy__card-title">Tactile over purely digital</div>
            <div class="pl-philosophy__card-desc">Real physical interaction creates moments that screens cannot replicate &mdash; touch, weight, space, and surprise become part of the story.</div>
          </div>
          <div class="pl-philosophy__card tla-fade tla-d1">
            <span class="pl-philosophy__card-icon">&#129309;</span>
            <div class="pl-philosophy__card-title">Shared adventure by design</div>
            <div class="pl-philosophy__card-desc">Built for groups, families, and friends &mdash; the experience is designed to be discovered together, not alone.</div>
          </div>
          <div class="pl-philosophy__card tla-fade tla-d2">
            <span class="pl-philosophy__card-icon">&#127761;</span>
            <div class="pl-philosophy__card-title">Atmosphere as a design material</div>
            <div class="pl-philosophy__card-desc">Light, space, timing, and mood are deliberate tools &mdash; every element contributes to the feeling of the journey.</div>
          </div>
          <div class="pl-philosophy__card tla-fade tla-d3">
            <span class="pl-philosophy__card-icon">&#127759;</span>
            <div class="pl-philosophy__card-title">Storytelling through place</div>
            <div class="pl-philosophy__card-desc">The environment is a co-author. Location, landscape, and architecture shape the narrative as much as any script.</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Collaboration CTA ──────────────────────────── -->
    <section class="pl-collaborate" id="collaborate">
      <div class="tla-container pl-collaborate__inner">
        <div class="pl-collaborate__text tla-fade">
          <span class="tla-overline">Early interest</span>
          <h2 class="tla-section-header">Interested in where this is going?</h2>
          <p>
            Puzzle Lanterns is in active development and we&rsquo;re open to early conversations. Whether you run a venue, organise events, or simply see a fit &mdash; we&rsquo;d love to hear from you.
          </p>
          <p>
            We&rsquo;re looking for pilot locations, creative partners, and people who believe physical experiences still have the power to surprise and connect.
          </p>
          <div class="pl-collaborate__ctas">
            <a href="mailto:hello@thelionsalliance.com" class="tla-btn tla-btn--gold">Get in touch</a>
            <a href="/" class="tla-btn tla-btn--outline">Explore the studio &rarr;</a>
          </div>
        </div>
        <div class="pl-collaborate__audiences tla-fade tla-d1">
          <ul class="pl-audience-list">
            <li class="pl-audience-item"><span class="pl-audience-dot"></span>Museums &amp; heritage venues</li>
            <li class="pl-audience-item"><span class="pl-audience-dot"></span>Campsites &amp; outdoor locations</li>
            <li class="pl-audience-item"><span class="pl-audience-dot"></span>Events &amp; experience venues</li>
            <li class="pl-audience-item"><span class="pl-audience-dot"></span>Tourism organisations</li>
            <li class="pl-audience-item"><span class="pl-audience-dot"></span>Early collaborators</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ── FAQ ────────────────────────────────────────── -->
    <section class="pl-faq">
      <div class="tla-container">
        <div class="tla-fade" style="text-align:center;">
          <span class="tla-overline">FAQ</span>
          <h2 class="tla-section-header">Common questions</h2>
        </div>
        <div class="pl-faq__list">
          <div class="pl-faq__item tla-fade">
            <div class="pl-faq__question">Is Puzzle Lanterns available yet?</div>
            <div class="pl-faq__answer">Not yet. Puzzle Lanterns is in active development &mdash; we are currently refining the interaction model and building the first prototype routes. Follow along or get in touch if you&rsquo;d like to be part of the journey.</div>
          </div>
          <div class="pl-faq__item tla-fade tla-d1">
            <div class="pl-faq__question">What kind of experience does it become?</div>
            <div class="pl-faq__answer">The format is adaptable. It could be a self-guided outdoor puzzle walk, a museum installation, or a venue-based storytelling experience. The interaction framework is designed to work across different contexts and scales.</div>
          </div>
          <div class="pl-faq__item tla-fade tla-d2">
            <div class="pl-faq__question">Can I collaborate?</div>
            <div class="pl-faq__answer">Yes &mdash; early conversations are welcome. We&rsquo;re especially interested in hearing from venues, event organisers, tourism bodies, and creative partners who see potential in physical storytelling experiences.</div>
          </div>
          <div class="pl-faq__item tla-fade tla-d3">
            <div class="pl-faq__question">Is this for events, venues, or public installations?</div>
            <div class="pl-faq__answer">Potentially all three. The modular design means Puzzle Lanterns can be adapted for a wide range of settings &mdash; from intimate campsite walks to large-scale public installations. The right format depends on the context.</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Footer ─────────────────────────────────────── -->
    <footer class="tla-footer">
      <div class="tla-container tla-footer__inner">
        <div class="tla-footer__brand">
          <div class="tla-footer__logo">The Lions Alliance</div>
          <p class="tla-footer__tagline">Creative studio for meaningful projects.</p>
        </div>
        <div class="tla-footer__links">
          <a href="/">Studio</a>
          <a href="#overview">Overview</a>
          <a href="#applications">Applications</a>
          <a href="#collaborate">Collaborate</a>
        </div>
      </div>
      <div class="tla-container tla-footer__bottom">
        <span>&copy; {year} The Lions Alliance. All rights reserved.</span>
      </div>
    </footer>

    <!-- ── Scripts ─────────────────────────────────────── -->
    <script>
      // Scroll-aware nav
      const nav = document.getElementById('tla-nav');
      if (nav) {
        window.addEventListener('scroll', () => {
          nav.classList.toggle('scrolled', window.scrollY > 40);
        });
      }

      // IntersectionObserver for fade-in
      const faders = document.querySelectorAll('.tla-fade');
      if (faders.length && 'IntersectionObserver' in window) {
        const obs = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('tla-visible');
                obs.unobserve(e.target);
              }
            });
          },
          { threshold: 0.15 }
        );
        faders.forEach((el) => obs.observe(el));
      } else {
        faders.forEach((el) => el.classList.add('tla-visible'));
      }

      // Hamburger toggle
      const hamburger = document.getElementById('hamburger');
      const mobileMenu = document.getElementById('mobile-menu');
      if (hamburger && mobileMenu) {
        hamburger.addEventListener('click', () => {
          const open = mobileMenu.classList.toggle('open');
          hamburger.classList.toggle('open', open);
          hamburger.setAttribute('aria-expanded', String(open));
        });
        mobileMenu.querySelectorAll('a').forEach((a) => {
          a.addEventListener('click', () => {
            mobileMenu.classList.remove('open');
            hamburger.classList.remove('open');
            hamburger.setAttribute('aria-expanded', 'false');
          });
        });
      }
    </script>
  </body>
</html>
