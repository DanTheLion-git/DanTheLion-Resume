---
import '../../../../styles/games.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Charades Admin</title>
  <style>
    .auth-card {
      background: var(--g-surface); border: 1px solid var(--g-border);
      border-radius: var(--g-radius); padding: 2rem 1.5rem;
      width: 100%; max-width: 380px;
      display: flex; flex-direction: column; gap: 1rem; margin: auto;
    }
    .auth-field { display: flex; flex-direction: column; gap: .3rem; }
    .auth-field label { font-size: .78rem; font-weight: 700; color: var(--g-muted); text-transform: uppercase; letter-spacing: .05em; }
    .auth-input { padding: .6rem .85rem; background: var(--g-bg); border: 1px solid var(--g-border); border-radius: var(--g-radius-sm); color: var(--g-text); font-size: .95rem; width: 100%; }
    .auth-input:focus { outline: none; border-color: var(--g-accent); }
    .pat-hint { font-size: .72rem; color: var(--g-muted); line-height: 1.5; }
    .lib-toolbar { position: sticky; top: 0; z-index: 10; background: var(--g-surface); border-bottom: 1px solid var(--g-border); padding: .6rem 1rem; display: flex; flex-direction: column; gap: .45rem; }
    .toolbar-row { display: flex; align-items: center; gap: .5rem; flex-wrap: wrap; }
    .lib-search { flex: 1; min-width: 120px; padding: .4rem .7rem; background: var(--g-bg); border: 1px solid var(--g-border); border-radius: var(--g-radius-sm); color: var(--g-text); font-size: .85rem; }
    .lib-search:focus { outline: none; border-color: var(--g-accent); }
    .mini-sel { padding: .38rem .4rem; background: var(--g-bg); border: 1px solid var(--g-border); border-radius: var(--g-radius-sm); color: var(--g-muted); font-size: .76rem; cursor: pointer; }
    .lib-meta { font-size: .73rem; color: var(--g-muted); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: .3rem; }
    .tbl-wrap { width: 100%; overflow-x: auto; padding: .5rem; }
    table.pt { width: 100%; border-collapse: collapse; font-size: .82rem; }
    table.pt thead th { background: var(--g-surface2); padding: .45rem .55rem; text-align: left; font-size: .7rem; font-weight: 700; letter-spacing: .05em; text-transform: uppercase; color: var(--g-muted); border-bottom: 1px solid var(--g-border); white-space: nowrap; cursor: pointer; user-select: none; }
    table.pt thead th:hover { color: var(--g-text); }
    table.pt thead th.sorted { color: var(--g-accent2); }
    table.pt tbody tr { border-bottom: 1px solid var(--g-border); }
    table.pt tbody tr:hover { background: rgba(255,255,255,.025); }
    table.pt td { padding: .4rem .45rem; vertical-align: middle; }
    .col-text { min-width: 160px; }
    .row-text { width: 100%; padding: .3rem .5rem; background: transparent; border: 1px solid transparent; border-radius: var(--g-radius-sm); color: var(--g-text); font-size: .84rem; transition: border-color .12s; }
    .row-text:hover { border-color: var(--g-border); }
    .row-text:focus { outline: none; border-color: var(--g-accent); background: var(--g-bg); }
    .row-sel { padding: .28rem .32rem; background: var(--g-bg); border: 1px solid var(--g-border); border-radius: var(--g-radius-sm); color: var(--g-muted); font-size: .74rem; cursor: pointer; width: 100%; }
    .row-sel:focus { outline: none; border-color: var(--g-accent); color: var(--g-text); }
    .row-del { background: none; border: none; color: var(--g-muted); cursor: pointer; font-size: 1.05rem; padding: .1rem .3rem; line-height: 1; }
    .row-del:hover { color: var(--g-accent); }
    .add-row td { background: rgba(29,185,84,.06); border-bottom: 2px solid var(--g-green) !important; }
    .save-banner { position: sticky; bottom: 0; background: var(--g-surface); border-top: 1px solid var(--g-border); padding: .6rem 1rem; display: flex; align-items: center; gap: .65rem; flex-wrap: wrap; }
    .dirty-label { flex: 1; font-size: .78rem; color: var(--g-accent2); }
    .status-notice { border-radius: var(--g-radius-sm); padding: .65rem .9rem; font-size: .82rem; margin: .5rem 1rem; display: none; }
    .status-notice.ok  { background: rgba(29,185,84,.12); border: 1px solid var(--g-green); color: var(--g-green); }
    .status-notice.err { background: rgba(255,80,80,.12);  border: 1px solid #ff5050; color: #ff8080; }
  </style>
</head>
<body class="game-page">

  <header class="game-header">
    <a href="/games/charades/" class="brand">🎭 Charades</a>
    <span id="admin-badge" class="hidden" style="font-size:.7rem;color:var(--g-muted);margin:0 auto;">🔒 Admin</span>
    <button id="btn-logout" class="g-btn outline small hidden" style="width:auto;">🔓 Logout</button>
  </header>

  <!-- ===== LOGIN ===== -->
  <div id="screen-login" class="game-content" style="justify-content:center;">
    <div class="auth-card">
      <div style="text-align:center;">
        <div style="font-size:1.8rem;">🔐</div>
        <div style="font-weight:800;font-size:1.2rem;margin-top:.25rem;">Admin Access</div>
        <p style="font-size:.8rem;color:var(--g-muted);margin-top:.3rem;">Prompt Library Editor</p>
      </div>
      <div class="auth-field">
        <label for="inp-user">Username</label>
        <input id="inp-user" class="auth-input" type="text" placeholder="admin" autocomplete="username" />
      </div>
      <div class="auth-field">
        <label for="inp-pass">Password</label>
        <input id="inp-pass" class="auth-input" type="password" placeholder="••••••••" autocomplete="current-password" />
      </div>
      <div class="auth-field">
        <label for="inp-pat">GitHub Personal Access Token
          <span style="font-weight:400;text-transform:none;letter-spacing:0;"> (to save to repo)</span>
        </label>
        <input id="inp-pat" class="auth-input" type="password" placeholder="github_pat_..." autocomplete="off" />
        <p class="pat-hint">
          Create at <strong>github.com → Settings → Developer settings → Fine-grained tokens</strong>.
          Needs <em>Contents: Read &amp; Write</em> on DanTheLion-Resume.
          Stored only in this browser session — never committed to code.
        </p>
      </div>
      <div id="login-error" class="g-alert error hidden">Incorrect username or password.</div>
      <button id="btn-login" class="g-btn primary" style="font-size:1rem;padding:.85rem;">Sign In →</button>
      <p style="font-size:.7rem;color:var(--g-muted);text-align:center;line-height:1.5;">
        ⚠️ Client-side password check — fine for a family party game.
      </p>
    </div>
  </div>

  <!-- ===== EDITOR ===== -->
  <div id="screen-editor" class="hidden" style="display:flex;flex-direction:column;min-height:calc(100vh - 52px);width:100%;">

    <div class="lib-toolbar">
      <div class="toolbar-row">
        <input id="lib-search" class="lib-search" placeholder="🔍 Search…" />
        <select id="lib-cat" class="mini-sel">
          <option value="">All categories</option>
          <option value="movies">🎬 Movies</option>
          <option value="books">📚 Books</option>
          <option value="artists">🎤 Artists</option>
          <option value="songs">🎵 Songs</option>
          <option value="places">🌍 Places</option>
          <option value="sayings">💬 Sayings</option>
          <option value="custom">⭐ Custom</option>
        </select>
        <select id="lib-diff" class="mini-sel">
          <option value="">All difficulties</option>
          <option value="easy">🟢 Easy</option>
          <option value="medium">🟡 Medium</option>
          <option value="hard">🔴 Hard</option>
        </select>
        <select id="lib-lang" class="mini-sel">
          <option value="">All languages</option>
          <option value="en">🇬🇧 EN</option>
          <option value="nl">🇳🇱 NL</option>
          <option value="any">Both</option>
        </select>
      </div>
      <div class="lib-meta">
        <span id="lib-count"></span>
        <button id="btn-reset-defaults" class="g-btn secondary small" style="font-size:.7rem;padding:.28rem .55rem;width:auto;">↺ Reset to original JSON</button>
      </div>
    </div>

    <div id="status-notice" class="status-notice"></div>

    <div class="tbl-wrap" style="flex:1;">
      <table class="pt">
        <thead>
          <tr>
            <th data-sort="text" class="sorted col-text">Text ▲</th>
            <th data-sort="category" style="min-width:88px;">Category</th>
            <th data-sort="difficulty" style="min-width:68px;">Difficulty</th>
            <th data-sort="lang" style="min-width:52px;">Lang</th>
            <th style="width:30px;cursor:default;"></th>
          </tr>
        </thead>
        <tbody id="add-row-body">
          <tr class="add-row">
            <td class="col-text"><input id="new-text" class="row-text" placeholder="New prompt…" maxlength="150" /></td>
            <td>
              <select id="new-cat" class="row-sel">
                <option value="custom">⭐ Custom</option>
                <option value="movies">🎬 Movies</option>
                <option value="books">📚 Books</option>
                <option value="artists">🎤 Artists</option>
                <option value="songs">🎵 Songs</option>
                <option value="places">🌍 Places</option>
                <option value="sayings">💬 Sayings</option>
              </select>
            </td>
            <td>
              <select id="new-diff" class="row-sel">
                <option value="easy">Easy</option>
                <option value="medium">Medium</option>
                <option value="hard">Hard</option>
              </select>
            </td>
            <td>
              <select id="new-lang" class="row-sel">
                <option value="any">Both</option>
                <option value="en">EN</option>
                <option value="nl">NL</option>
              </select>
            </td>
            <td>
              <button id="btn-add-row" class="g-btn green small" style="padding:.28rem .55rem;width:auto;font-size:.82rem;">+ Add</button>
            </td>
          </tr>
        </tbody>
        <tbody id="prompts-tbody"></tbody>
      </table>
    </div>

    <div class="save-banner">
      <span class="dirty-label" id="dirty-label"></span>
      <button id="btn-undo" class="g-btn secondary small" style="width:auto;">↩ Undo</button>
      <button id="btn-save-local" class="g-btn secondary small" style="width:auto;">💾 Save locally</button>
      <button id="btn-save-github" class="g-btn green" style="width:auto;padding:.5rem 1.1rem;font-size:.9rem;">🚀 Save to Repository</button>
    </div>
  </div>

  <script is:inline>
    // SHA-256 of "Hondje01" — password never stored in plain text in code
    const PW_HASH       = '54ca8367f2de81e6c62cfb2d4bf7b29ec0a20c5623e7301336a49021b35e549c';
    const EXPECTED_USER = 'admin';
    const LS_ALL        = 'charades_prompts_all';
    const SS_PAT        = 'charades_admin_pat';
    const REPO_API      = 'https://api.github.com/repos/DanTheLion-git/DanTheLion-Resume/contents/Astro-Resume/public/charades/prompts.json';

    const CAT_OPTS  = [{v:'movies',l:'🎬 Movies'},{v:'books',l:'📚 Books'},{v:'artists',l:'🎤 Artists'},{v:'songs',l:'🎵 Songs'},{v:'places',l:'🌍 Places'},{v:'sayings',l:'💬 Sayings'},{v:'custom',l:'⭐ Custom'}];
    const DIFF_OPTS = [{v:'easy',l:'🟢 Easy'},{v:'medium',l:'🟡 Medium'},{v:'hard',l:'🔴 Hard'}];
    const LANG_OPTS = [{v:'any',l:'Both'},{v:'en',l:'🇬🇧 EN'},{v:'nl',l:'🇳🇱 NL'}];

    const $ = id => document.getElementById(id);

    /* ── Screen toggle ─────────────────────────────────────────────────── */
    function showScreen(s) {
      const login  = $('screen-login');
      const editor = $('screen-editor');
      const logout = $('btn-logout');
      const badge  = $('admin-badge');
      if (s === 'login') {
        login.classList.remove('hidden');
        editor.classList.add('hidden'); editor.style.display = 'none';
        logout.classList.add('hidden'); badge.classList.add('hidden');
      } else {
        login.classList.add('hidden');
        editor.classList.remove('hidden'); editor.style.display = 'flex';
        logout.classList.remove('hidden'); badge.classList.remove('hidden');
      }
    }

    /* ── Auth ──────────────────────────────────────────────────────────── */
    async function hashString(s) {
      const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(s));
      return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2,'0')).join('');
    }

    $('btn-login').addEventListener('click', async () => {
      const user = $('inp-user').value.trim();
      const pass = $('inp-pass').value;
      const pat  = $('inp-pat').value.trim();
      if (user !== EXPECTED_USER || await hashString(pass) !== PW_HASH) {
        $('login-error').classList.remove('hidden'); return;
      }
      $('login-error').classList.add('hidden');
      if (pat) sessionStorage.setItem(SS_PAT, pat);
      await initEditor();
      showScreen('editor');
    });

    ['inp-pass','inp-pat'].forEach(id =>
      $(id).addEventListener('keydown', e => { if (e.key === 'Enter') $('btn-login').click(); })
    );

    $('btn-logout').addEventListener('click', () => {
      sessionStorage.removeItem(SS_PAT);
      showScreen('login');
    });

    /* ── Data ──────────────────────────────────────────────────────────── */
    let allPrompts = [], savedSnapshot = [], isDirty = false, counter = 1;
    function newId() { return 'a_' + (counter++) + '_' + Math.random().toString(36).slice(2,6); }
    function withIds(arr) { return arr.map(p => ({ ...p, _id: p._id || newId() })); }

    async function initEditor() {
      const cached = localStorage.getItem(LS_ALL);
      if (cached) {
        allPrompts = withIds(JSON.parse(cached));
      } else {
        const res = await fetch('/charades/prompts.json?t=' + Date.now());
        allPrompts = withIds(await res.json());
      }
      savedSnapshot = allPrompts.map(p => ({...p}));
      markClean(); renderTable();
    }

    function markDirty() { isDirty = true;  $('dirty-label').textContent = '⚠️ Unsaved changes'; }
    function markClean() { isDirty = false; $('dirty-label').textContent = ''; }

    /* ── Filter / sort ─────────────────────────────────────────────────── */
    let sortCol = 'text', sortDir = 'asc';
    const Q    = () => $('lib-search').value.toLowerCase().trim();
    const FCAT = () => $('lib-cat').value;
    const FDIF = () => $('lib-diff').value;
    const FLAN = () => $('lib-lang').value;

    function filtered() {
      const q = Q();
      return allPrompts.filter(p =>
        (!q      || p.text.toLowerCase().includes(q)) &&
        (!FCAT() || p.category   === FCAT()) &&
        (!FDIF() || p.difficulty === FDIF()) &&
        (!FLAN() || p.lang       === FLAN())
      );
    }

    function sorted(list) {
      return [...list].sort((a,b) => {
        const av = String(a[sortCol]||''), bv = String(b[sortCol]||'');
        return sortDir === 'asc' ? av.localeCompare(bv) : bv.localeCompare(av);
      });
    }

    function esc(s) {
      return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function makeSelect(field, opts, val) {
      return '<select class="row-sel" data-field="' + field + '">' +
        opts.map(o => '<option value="' + o.v + '"' + (o.v === val ? ' selected' : '') + '>' + esc(o.l) + '</option>').join('') +
        '</select>';
    }

    /* ── Render table ──────────────────────────────────────────────────── */
    function renderTable() {
      const list = sorted(filtered());
      const tbody = $('prompts-tbody');
      tbody.innerHTML = '';
      $('lib-count').textContent = list.length + ' of ' + allPrompts.length + ' prompts';

      list.forEach(p => {
        const tr = document.createElement('tr');
        tr.dataset.id = p._id;
        tr.innerHTML =
          '<td class="col-text"><input type="text" class="row-text" value="' + esc(p.text) + '" maxlength="150" /></td>' +
          '<td>' + makeSelect('category',   CAT_OPTS,  p.category)   + '</td>' +
          '<td>' + makeSelect('difficulty', DIFF_OPTS, p.difficulty) + '</td>' +
          '<td>' + makeSelect('lang',       LANG_OPTS, p.lang)       + '</td>' +
          '<td><button class="row-del" title="Delete">✕</button></td>';

        tr.querySelector('.row-text').addEventListener('input', e => {
          const found = allPrompts.find(x => x._id === tr.dataset.id);
          if (found) { found.text = e.target.value; markDirty(); }
        });
        tr.querySelectorAll('.row-sel').forEach(sel => {
          sel.addEventListener('change', () => {
            const found = allPrompts.find(x => x._id === tr.dataset.id);
            if (found) { found[sel.dataset.field] = sel.value; markDirty(); }
          });
        });
        tr.querySelector('.row-del').addEventListener('click', () => {
          if (!confirm('Delete "' + p.text + '"?')) return;
          allPrompts = allPrompts.filter(x => x._id !== tr.dataset.id);
          tr.remove();
          $('lib-count').textContent = filtered().length + ' of ' + allPrompts.length + ' prompts';
          markDirty();
        });
        tbody.appendChild(tr);
      });
    }

    document.querySelectorAll('table.pt thead th[data-sort]').forEach(th => {
      th.addEventListener('click', () => {
        const col = th.dataset.sort;
        sortDir = (sortCol === col && sortDir === 'asc') ? 'desc' : 'asc';
        sortCol = col;
        document.querySelectorAll('table.pt thead th').forEach(h => {
          h.classList.remove('sorted');
          h.textContent = h.textContent.replace(/ [▲▼]$/, '');
          if (h.dataset.sort === col) { h.classList.add('sorted'); h.textContent += sortDir === 'asc' ? ' ▲' : ' ▼'; }
        });
        renderTable();
      });
    });

    ['lib-search','lib-cat','lib-diff','lib-lang'].forEach(id =>
      $(id).addEventListener('input', renderTable)
    );

    /* ── Add row ───────────────────────────────────────────────────────── */
    $('btn-add-row').addEventListener('click', () => {
      const inp = $('new-text');
      const text = inp.value.trim();
      if (!text) { inp.focus(); return; }
      allPrompts.unshift({
        _id: newId(), text,
        category:   $('new-cat').value,
        difficulty: $('new-diff').value,
        lang:       $('new-lang').value,
      });
      inp.value = ''; inp.focus(); markDirty(); renderTable();
    });
    $('new-text').addEventListener('keydown', e => { if (e.key === 'Enter') $('btn-add-row').click(); });

    /* ── Save locally ──────────────────────────────────────────────────── */
    $('btn-save-local').addEventListener('click', () => {
      localStorage.setItem(LS_ALL, JSON.stringify(allPrompts));
      savedSnapshot = allPrompts.map(p => ({...p}));
      markClean();
      showStatus('ok', '💾 Saved to browser storage! The game on this device will use these prompts immediately.');
    });

    /* ── Undo ──────────────────────────────────────────────────────────── */
    $('btn-undo').addEventListener('click', () => {
      if (!isDirty) return;
      if (!confirm('Undo all unsaved changes?')) return;
      allPrompts = savedSnapshot.map(p => ({...p}));
      markClean(); renderTable();
    });

    /* ── Reset to defaults ─────────────────────────────────────────────── */
    $('btn-reset-defaults').addEventListener('click', async () => {
      if (!confirm('Reset ALL prompts to the original JSON from the repository? This cannot be undone.')) return;
      localStorage.removeItem(LS_ALL);
      const res = await fetch('/charades/prompts.json?t=' + Date.now());
      allPrompts = withIds(await res.json());
      savedSnapshot = allPrompts.map(p => ({...p}));
      markClean(); renderTable();
      showStatus('ok', '↺ Reset to original prompts.json.');
    });

    /* ── Status banner ─────────────────────────────────────────────────── */
    function showStatus(type, msg) {
      const el = $('status-notice');
      el.className = 'status-notice ' + type;
      el.textContent = msg;
      el.style.display = 'block';
      setTimeout(() => { el.style.display = 'none'; }, 12000);
    }

    /* ── UTF-8 → Base64 (for GitHub API) ──────────────────────────────── */
    function utf8ToBase64(str) {
      const bytes = new TextEncoder().encode(str);
      let bin = '';
      bytes.forEach(b => bin += String.fromCharCode(b));
      return btoa(bin);
    }

    /* ── Save to GitHub repository ─────────────────────────────────────── */
    $('btn-save-github').addEventListener('click', async () => {
      const pat = sessionStorage.getItem(SS_PAT);
      if (!pat) {
        showStatus('err', '❌ No GitHub token found. Please log out and sign in again with your PAT.');
        return;
      }

      const btn = $('btn-save-github');
      const origText = btn.textContent;
      btn.textContent = '⏳ Saving…'; btn.disabled = true;

      try {
        // 1. Get current file SHA from GitHub API
        const getRes = await fetch(REPO_API, {
          headers: {
            Authorization: 'token ' + pat,
            Accept: 'application/vnd.github.v3+json',
          },
        });

        if (getRes.status === 401) throw new Error('GitHub token is invalid or expired. Please log out and sign in with a fresh PAT.');
        if (getRes.status === 403) throw new Error('GitHub token does not have write access to this repository.');
        if (!getRes.ok) throw new Error('GitHub API error ' + getRes.status + ' when reading file.');

        const fileData = await getRes.json();
        const currentSha = fileData.sha;

        // 2. Prepare clean prompt data — strip runtime _id, renumber sequentially
        const cleanPrompts = allPrompts.map((p, i) => ({
          id:         p.id !== undefined ? p.id : (1000 + i),
          text:       p.text,
          category:   p.category,
          difficulty: p.difficulty,
          lang:       p.lang,
        }));

        const json    = JSON.stringify(cleanPrompts, null, 2);
        const content = utf8ToBase64(json);

        // 3. PUT updated file
        const putRes = await fetch(REPO_API, {
          method: 'PUT',
          headers: {
            Authorization: 'token ' + pat,
            Accept: 'application/vnd.github.v3+json',
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            message: 'chore: update charades prompts via admin panel (' + new Date().toISOString().slice(0,10) + ')',
            content,
            sha: currentSha,
          }),
        });

        if (!putRes.ok) {
          const err = await putRes.json().catch(() => ({}));
          throw new Error(err.message || 'Save failed with status ' + putRes.status);
        }

        // 4. Also persist locally so admin sees same data immediately
        localStorage.setItem(LS_ALL, JSON.stringify(allPrompts));
        savedSnapshot = allPrompts.map(p => ({...p}));
        markClean();

        showStatus('ok',
          '✅ Saved to repository! GitHub Actions is rebuilding the site (~1–2 min). ' +
          'All players will see the updated prompts after the next page load.'
        );
      } catch (err) {
        showStatus('err', '❌ ' + err.message);
      } finally {
        btn.textContent = origText; btn.disabled = false;
      }
    });
  </script>
</body>
</html>
