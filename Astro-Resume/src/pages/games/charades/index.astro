---
import '../../../styles/games.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no" />
  <title>Charades — The Lions Alliance</title>

  <style>
    /* ── Charades-specific styles ─────────────────────────────────────── */
    .setup-section {
      background: var(--g-surface);
      border: 1px solid var(--g-border);
      border-radius: var(--g-radius);
      padding: 1rem;
      width: 100%;
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
    }

    /* Toggle chips for language / category / difficulty */
    .chip-group { display: flex; flex-wrap: wrap; gap: 0.4rem; }

    .chip {
      padding: 0.4rem 0.85rem;
      border-radius: 999px;
      border: 1.5px solid var(--g-border);
      background: var(--g-bg);
      color: var(--g-muted);
      font-size: 0.82rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.12s;
      user-select: none;
    }

    .chip.active {
      border-color: var(--g-accent);
      background: rgba(233,69,96,0.15);
      color: var(--g-text);
    }

    .chip.lang-active {
      border-color: #5882ff;
      background: rgba(88,130,255,0.15);
      color: #a0b4ff;
    }

    /* Team list */
    .team-row {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .team-row input[type="text"] {
      flex: 1;
      padding: 0.5rem 0.75rem;
      background: var(--g-bg);
      border: 1px solid var(--g-border);
      border-radius: var(--g-radius-sm);
      color: var(--g-text);
      font-size: 0.9rem;
    }

    .team-row input[type="text"]:focus {
      outline: none;
      border-color: var(--g-accent);
    }

    .btn-remove-team {
      background: none;
      border: none;
      color: var(--g-muted);
      font-size: 1.1rem;
      cursor: pointer;
      padding: 0.25rem;
      line-height: 1;
    }

    .btn-remove-team:hover { color: var(--g-accent); }

    /* Timer ring */
    .timer-ring {
      position: relative;
      width: 110px;
      height: 110px;
      flex-shrink: 0;
    }

    .timer-ring svg {
      transform: rotate(-90deg);
      width: 110px;
      height: 110px;
    }

    .timer-ring .ring-bg   { fill: none; stroke: var(--g-border);   stroke-width: 6; }
    .timer-ring .ring-fill { fill: none; stroke: var(--g-green);    stroke-width: 6;
                              stroke-linecap: round; transition: stroke 0.3s, stroke-dashoffset 0.2s linear; }

    .timer-ring .timer-text {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.6rem;
      font-weight: 900;
      color: var(--g-text);
      transition: color 0.3s;
    }

    .timer-ring.urgent .ring-fill { stroke: var(--g-accent); }
    .timer-ring.urgent .timer-text { color: var(--g-accent); }
    .timer-ring.urgent .timer-text { animation: pulse-text 0.5s ease infinite alternate; }

    @keyframes pulse-text { from { opacity: 1; } to { opacity: 0.5; } }

    /* Prompt card */
    .prompt-card {
      background: var(--g-surface);
      border: 2px solid var(--g-border);
      border-radius: var(--g-radius);
      padding: 1.5rem 1rem;
      width: 100%;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
      min-height: 160px;
      justify-content: center;
    }

    .prompt-category {
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--g-muted);
      display: flex;
      align-items: center;
      gap: 0.3rem;
    }

    .prompt-text {
      font-size: clamp(1.4rem, 5vw, 2rem);
      font-weight: 800;
      color: var(--g-text);
      line-height: 1.2;
    }

    .prompt-diff {
      font-size: 0.7rem;
      padding: 2px 8px;
      border-radius: 999px;
    }

    .diff-easy   { background: rgba(29,185,84,0.2);  color: var(--g-green); }
    .diff-medium { background: rgba(245,166,35,0.2); color: var(--g-accent2); }
    .diff-hard   { background: rgba(233,69,96,0.2);  color: var(--g-accent); }

    /* Game action buttons */
    .action-row {
      display: flex;
      gap: 0.75rem;
      width: 100%;
    }

    .btn-got-it {
      flex: 2;
      background: var(--g-green);
      color: white;
      font-size: 1.1rem;
      padding: 1.1rem;
    }

    .btn-skip {
      flex: 1;
      background: var(--g-surface2);
      border: 1px solid var(--g-border);
      color: var(--g-muted);
      font-size: 1rem;
      padding: 1.1rem;
    }

    /* Score table */
    .scores-table { width: 100%; border-collapse: collapse; }
    .scores-table td { padding: 0.5rem 0.25rem; border-bottom: 1px solid var(--g-border); font-size: 0.9rem; }
    .scores-table tr:last-child td { border-bottom: none; }
    .scores-table .score-name   { color: var(--g-text); font-weight: 600; }
    .scores-table .score-pts    { text-align: right; color: var(--g-accent2); font-weight: 700; font-size: 1rem; }
    .scores-table tr.current-team td { color: var(--g-accent); }

    /* Team ready screen */
    .team-badge {
      font-size: 3rem;
      font-weight: 900;
      color: var(--g-accent);
      text-align: center;
      line-height: 1;
    }

    /* Game over podium */
    .podium-row {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.75rem;
      border-radius: var(--g-radius-sm);
      background: var(--g-surface);
      border: 1px solid var(--g-border);
    }

    .podium-row.first  { border-color: #f5a623; background: rgba(245,166,35,0.1); }
    .podium-row.second { border-color: #888; background: rgba(136,136,136,0.08); }
    .podium-row.third  { border-color: #cd7f32; background: rgba(205,127,50,0.08); }

    .podium-rank   { font-size: 1.5rem; width: 2rem; text-align: center; flex-shrink: 0; }
    .podium-name   { flex: 1; font-weight: 700; font-size: 1rem; }
    .podium-score  { font-weight: 800; color: var(--g-accent2); font-size: 1.1rem; }

    /* Range input */
    input[type="range"] {
      width: 100%;
      accent-color: var(--g-accent);
    }
  </style>
</head>

<body class="game-page">

  <header class="game-header">
    <a href="/games/" class="brand">🦁 Games</a>
    <button id="btn-rules" class="g-btn secondary small" style="width:auto;">Rules</button>
  </header>

  <!-- ══ RULES MODAL ══════════════════════════════════════════════════════ -->
  <div id="modal-rules" class="hidden" style="
    position:fixed;inset:0;background:rgba(0,0,0,0.75);z-index:100;
    display:flex;align-items:center;justify-content:center;padding:1rem;
  ">
    <div class="g-card" style="max-width:420px;display:flex;flex-direction:column;gap:0.75rem;max-height:90vh;overflow-y:auto;">
      <div style="display:flex;justify-content:space-between;align-items:center;">
        <strong>🎭 How to Play Charades</strong>
        <button id="btn-close-rules" class="g-btn secondary small" style="width:auto;">✕</button>
      </div>
      <ol style="padding-left:1.25rem;font-size:0.9rem;line-height:1.8;color:var(--g-muted);">
        <li>Teams take turns. The acting player <strong>holds the phone</strong>.</li>
        <li>Tap <strong>Start Round</strong> — a prompt appears on screen.</li>
        <li>Act it out silently — <strong>no speaking, no sounds</strong>.</li>
        <li>Your team guesses — tap <strong>✓ Got it!</strong> for each correct guess.</li>
        <li>Tap <strong>Skip</strong> to pass on a prompt (no penalty).</li>
        <li>When the timer runs out, the round ends.</li>
        <li>The team with the most points after all rounds wins! 🏆</li>
      </ol>
      <p style="font-size:0.8rem;color:var(--g-muted);">
        Classic gestures: film → wind imaginary camera ·
        book → open palms · song → mime singing · TV show → draw rectangle
      </p>
    </div>
  </div>

  <!-- ══ SETUP ════════════════════════════════════════════════════════════ -->
  <div id="screen-setup" class="game-content" style="gap:1rem;">

    <div style="text-align:center;">
      <div style="font-size:2rem;font-weight:900;background:linear-gradient(135deg,var(--g-accent),var(--g-accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">CHARADES</div>
      <p class="g-subtitle">Act it out — no talking!</p>
    </div>

    <!-- Language -->
    <div class="setup-section">
      <div class="g-label">Language / Taal</div>
      <div class="chip-group" id="lang-chips">
        <div class="chip lang-active" data-lang="en">🇬🇧 English</div>
        <div class="chip lang-active" data-lang="nl">🇳🇱 Nederlands</div>
      </div>
    </div>

    <!-- Categories -->
    <div class="setup-section">
      <div class="g-label">Categories / Categorieën</div>
      <div class="chip-group" id="cat-chips">
        <div class="chip active" data-cat="movies">🎬 Movies</div>
        <div class="chip active" data-cat="books">📚 Books</div>
        <div class="chip active" data-cat="artists">🎤 Artists</div>
        <div class="chip active" data-cat="songs">🎵 Songs</div>
        <div class="chip active" data-cat="places">🌍 Places</div>
        <div class="chip active" data-cat="sayings">💬 Sayings</div>
      </div>
    </div>

    <!-- Difficulty -->
    <div class="setup-section">
      <div class="g-label">Difficulty / Moeilijkheidsgraad</div>
      <div class="chip-group" id="diff-chips">
        <div class="chip active" data-diff="easy">🟢 Easy</div>
        <div class="chip active" data-diff="medium">🟡 Medium</div>
        <div class="chip active" data-diff="hard">🔴 Hard</div>
      </div>
    </div>

    <!-- Timer -->
    <div class="setup-section">
      <div style="display:flex;justify-content:space-between;align-items:center;">
        <div class="g-label">Timer per round</div>
        <div id="timer-display" style="font-weight:700;color:var(--g-accent2);font-size:1rem;">60s</div>
      </div>
      <input type="range" id="timer-range" min="30" max="120" step="15" value="60" />
      <div style="display:flex;justify-content:space-between;font-size:0.7rem;color:var(--g-muted);">
        <span>30s</span><span>60s</span><span>90s</span><span>120s</span>
      </div>
    </div>

    <!-- Rounds per team -->
    <div class="setup-section">
      <div style="display:flex;justify-content:space-between;align-items:center;">
        <div class="g-label">Rounds per team</div>
        <div id="rounds-display" style="font-weight:700;color:var(--g-accent2);font-size:1rem;">3</div>
      </div>
      <input type="range" id="rounds-range" min="1" max="8" step="1" value="3" />
    </div>

    <!-- Teams -->
    <div class="setup-section">
      <div class="g-label">Teams</div>
      <div id="teams-list" style="display:flex;flex-direction:column;gap:0.4rem;"></div>
      <button id="btn-add-team" class="g-btn secondary" style="font-size:0.85rem;padding:0.5rem;">+ Add Team</button>
      <div id="teams-error" class="g-alert error hidden">Add at least 2 teams.</div>
    </div>

    <!-- Custom words -->
    <div class="setup-section">
      <div class="g-label">Custom words / phrases ⭐</div>
      <textarea
        id="custom-words"
        rows="3"
        placeholder="Comma-separated, e.g.: Uncle Bob dancing, The family dog, Christmas dinner…"
        style="
          width:100%;padding:0.6rem 0.75rem;
          background:var(--g-bg);border:1px solid var(--g-border);
          border-radius:var(--g-radius-sm);color:var(--g-text);
          font-size:0.85rem;resize:vertical;font-family:inherit;
        "
      ></textarea>
    </div>

    <div id="pool-warning" class="g-alert error hidden">
      No prompts match your settings. Try enabling more categories or difficulties.
    </div>

    <button id="btn-start" class="g-btn primary" style="font-size:1.1rem;padding:1.1rem;">
      🎭 Start Game
    </button>

  </div><!-- /screen-setup -->


  <!-- ══ TEAM READY ════════════════════════════════════════════════════════ -->
  <div id="screen-team-ready" class="game-content hidden" style="gap:1.5rem;">

    <div style="text-align:center;display:flex;flex-direction:column;gap:0.5rem;align-items:center;">
      <div class="g-subtitle">It's time for…</div>
      <div class="team-badge" id="ready-team-name">Team 1</div>
      <div id="ready-round-info" class="g-label"></div>
    </div>

    <div class="g-card" style="text-align:center;display:flex;flex-direction:column;gap:0.5rem;">
      <p style="font-size:0.9rem;color:var(--g-muted);">
        Pass the phone to the person who will act. When they're ready, tap the button below.
      </p>
    </div>

    <!-- Quick scoreboard -->
    <div class="g-card" style="padding:0.75rem;">
      <div class="g-label" style="margin-bottom:0.5rem;">Current Scores</div>
      <table class="scores-table" id="ready-scores"></table>
    </div>

    <button id="btn-ready-start" class="g-btn green" style="font-size:1.1rem;padding:1.2rem;">
      ▶ Start Round
    </button>

  </div><!-- /screen-team-ready -->


  <!-- ══ PLAYING ════════════════════════════════════════════════════════════ -->
  <div id="screen-playing" class="game-content hidden" style="gap:1rem;">

    <div style="display:flex;align-items:center;justify-content:space-between;width:100%;">
      <div>
        <div id="play-team-name" style="font-weight:700;font-size:1rem;"></div>
        <div id="play-round-pts" class="g-label"></div>
      </div>
      <div class="timer-ring" id="timer-ring">
        <svg viewBox="0 0 110 110">
          <circle class="ring-bg"   cx="55" cy="55" r="48" />
          <circle class="ring-fill" id="ring-fill" cx="55" cy="55" r="48"
                  stroke-dasharray="301.59" stroke-dashoffset="0" />
        </svg>
        <div class="timer-text" id="timer-text">60</div>
      </div>
    </div>

    <div class="prompt-card" id="prompt-card">
      <div class="prompt-category" id="prompt-cat">🎬 Movie</div>
      <div class="prompt-text"     id="prompt-text">Loading…</div>
      <div class="prompt-diff"     id="prompt-diff"></div>
    </div>

    <div class="action-row">
      <button class="g-btn btn-got-it" id="btn-got-it">✓ Got it!</button>
      <button class="g-btn btn-skip"   id="btn-skip">✗ Skip</button>
    </div>

    <button id="btn-pause" class="g-btn secondary" style="font-size:0.85rem;padding:0.5rem;">⏸ Pause</button>

  </div><!-- /screen-playing -->


  <!-- ══ ROUND END ══════════════════════════════════════════════════════════ -->
  <div id="screen-round-end" class="game-content hidden" style="gap:1.25rem;">

    <div style="text-align:center;">
      <div style="font-size:2.5rem;">⏰</div>
      <div style="font-weight:800;font-size:1.3rem;margin-top:0.25rem;" id="round-end-title">Time's up!</div>
    </div>

    <div class="g-card" style="text-align:center;display:flex;flex-direction:column;gap:0.25rem;">
      <div class="g-label">Round score — <span id="round-end-team"></span></div>
      <div style="font-size:3rem;font-weight:900;color:var(--g-green);" id="round-end-pts">0</div>
      <div style="font-size:0.85rem;color:var(--g-muted);" id="round-end-skips"></div>
    </div>

    <div class="g-card" style="padding:0.75rem;">
      <div class="g-label" style="margin-bottom:0.5rem;">Scoreboard</div>
      <table class="scores-table" id="round-end-scores"></table>
    </div>

    <button id="btn-next-team" class="g-btn primary" style="font-size:1.05rem;">
      Next Team →
    </button>

  </div><!-- /screen-round-end -->


  <!-- ══ GAME OVER ═══════════════════════════════════════════════════════════ -->
  <div id="screen-game-over" class="game-content hidden" style="gap:1.25rem;">

    <div style="text-align:center;">
      <div style="font-size:2.5rem;">🏆</div>
      <div style="font-weight:900;font-size:1.5rem;margin-top:0.25rem;">Game Over!</div>
      <div class="g-subtitle" id="winner-text"></div>
    </div>

    <div id="podium" style="display:flex;flex-direction:column;gap:0.5rem;width:100%;"></div>

    <button id="btn-play-again"   class="g-btn green"     style="font-size:1.05rem;">↺ Play Again</button>
    <button id="btn-change-setup" class="g-btn secondary"  style="font-size:0.9rem;">⚙ Change Settings</button>

  </div><!-- /screen-game-over -->


  <!-- ══ SCRIPTS ══════════════════════════════════════════════════════════ -->
  <script>
    // ── Types ──────────────────────────────────────────────────────────────
    interface Prompt {
      id:         number;
      text:       string;
      category:   string;
      difficulty: string;
      lang:       'en' | 'nl' | 'any';
    }

    interface Team {
      name:  string;
      score: number;
      rounds: number;
    }

    interface GameConfig {
      langs:         string[];
      cats:          string[];
      diffs:         string[];
      timePerRound:  number;
      roundsPerTeam: number;
      teams:         Team[];
      customWords:   string[];
    }

    type Screen = 'setup' | 'team-ready' | 'playing' | 'round-end' | 'game-over';

    // ── DOM ────────────────────────────────────────────────────────────────
    const $   = (id: string) => document.getElementById(id)!;
    const show = (...ids: string[]) => ids.forEach(id => $(id).classList.remove('hidden'));
    const hide = (...ids: string[]) => ids.forEach(id => $(id).classList.add('hidden'));

    function showScreen(s: Screen) {
      (['setup','team-ready','playing','round-end','game-over'] as Screen[]).forEach(sc =>
        hide(`screen-${sc}`)
      );
      show(`screen-${s}`);
    }

    // ── Setup: chip toggles ────────────────────────────────────────────────
    document.querySelectorAll<HTMLElement>('#lang-chips .chip').forEach(chip => {
      chip.addEventListener('click', () => {
        chip.classList.toggle('lang-active');
      });
    });

    document.querySelectorAll<HTMLElement>('#cat-chips .chip').forEach(chip => {
      chip.addEventListener('click', () => chip.classList.toggle('active'));
    });

    document.querySelectorAll<HTMLElement>('#diff-chips .chip').forEach(chip => {
      chip.addEventListener('click', () => chip.classList.toggle('active'));
    });

    // ── Setup: sliders ─────────────────────────────────────────────────────
    const timerRange  = $('timer-range')  as HTMLInputElement;
    const roundsRange = $('rounds-range') as HTMLInputElement;

    timerRange.addEventListener('input',  () => { $('timer-display').textContent  = timerRange.value  + 's'; });
    roundsRange.addEventListener('input', () => { $('rounds-display').textContent = roundsRange.value; });

    // ── Setup: teams ───────────────────────────────────────────────────────
    const teamsList = $('teams-list');
    let teamCount   = 0;

    function addTeam(name = '') {
      if (teamCount >= 6) return;
      teamCount++;
      const idx = teamCount;
      const row = document.createElement('div');
      row.className = 'team-row';
      row.dataset.idx = String(idx);
      row.innerHTML = `
        <input type="text" placeholder="Team ${idx}" value="${name}" maxlength="20" />
        <button class="btn-remove-team" title="Remove team">✕</button>
      `;
      row.querySelector('.btn-remove-team')!.addEventListener('click', () => {
        row.remove();
        teamCount = Math.max(0, teamCount - 1);
      });
      teamsList.appendChild(row);
    }

    addTeam('Lions');
    addTeam('Cubs');

    $('btn-add-team').addEventListener('click', () => addTeam());

    // ── Rules modal ────────────────────────────────────────────────────────
    $('btn-rules').addEventListener('click', () => {
      $('modal-rules').style.display = 'flex';
    });
    $('btn-close-rules').addEventListener('click', () => {
      $('modal-rules').style.display = 'none';
    });
    $('modal-rules').addEventListener('click', (e) => {
      if (e.target === $('modal-rules')) $('modal-rules').style.display = 'none';
    });

    // ── Game state ─────────────────────────────────────────────────────────
    let allPrompts:     Prompt[] = [];
    let promptQueue:    Prompt[] = [];
    let config:         GameConfig;
    let currentTeamIdx: number   = 0;
    let roundScore:     number   = 0;
    let roundSkips:     number   = 0;
    let timerEndTime:   number   = 0;
    let timerInterval:  number | null = null;
    let isPaused        = false;
    let timeRemaining   = 60;

    const CIRCUMFERENCE = 2 * Math.PI * 48; // r=48

    // ── Category meta ──────────────────────────────────────────────────────
    const CAT_META: Record<string, { icon: string; en: string; nl: string }> = {
      movies:  { icon: '🎬', en: 'Movie',   nl: 'Film'      },
      books:   { icon: '📚', en: 'Book',    nl: 'Boek'      },
      artists: { icon: '🎤', en: 'Artist',  nl: 'Artiest'   },
      songs:   { icon: '🎵', en: 'Song',    nl: 'Nummer'    },
      places:  { icon: '🌍', en: 'Place',   nl: 'Plaats'    },
      sayings: { icon: '💬', en: 'Saying',  nl: 'Gezegde'   },
      custom:  { icon: '⭐', en: 'Custom',  nl: 'Eigen'     },
    };

    function catLabel(cat: string): string {
      const m   = CAT_META[cat];
      const isNL = config?.langs.includes('nl') && !config.langs.includes('en');
      return m ? `${m.icon} ${isNL ? m.nl : m.en}` : cat;
    }

    // ── Prompt loading & filtering ─────────────────────────────────────────
    async function loadPrompts(): Promise<Prompt[]> {
      if (allPrompts.length) return allPrompts;
      const res = await fetch('/charades/prompts.json');
      allPrompts = await res.json();
      return allPrompts;
    }

    function shuffle<T>(arr: T[]): T[] {
      const a = [...arr];
      for (let i = a.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [a[i], a[j]] = [a[j], a[i]];
      }
      return a;
    }

    function buildQueue(cfg: GameConfig, base: Prompt[]): Prompt[] {
      const custom: Prompt[] = cfg.customWords
        .filter(w => w.trim())
        .map((w, i) => ({
          id: 9000 + i,
          text: w.trim(),
          category: 'custom',
          difficulty: 'medium',
          lang: 'any' as const,
        }));

      const filtered = base.filter(p => {
        const langOk  = p.lang === 'any' || cfg.langs.includes(p.lang);
        const catOk   = cfg.cats.includes(p.category);
        const diffOk  = cfg.diffs.includes(p.difficulty);
        return langOk && catOk && diffOk;
      });

      return shuffle([...filtered, ...custom]);
    }

    // ── Build config from UI ───────────────────────────────────────────────
    function readConfig(): GameConfig | null {
      const langs = Array.from(document.querySelectorAll<HTMLElement>('#lang-chips .lang-active'))
        .map(c => c.dataset.lang!);
      const cats  = Array.from(document.querySelectorAll<HTMLElement>('#cat-chips .active'))
        .map(c => c.dataset.cat!);
      const diffs = Array.from(document.querySelectorAll<HTMLElement>('#diff-chips .active'))
        .map(c => c.dataset.diff!);

      const timePerRound  = parseInt(timerRange.value,  10);
      const roundsPerTeam = parseInt(roundsRange.value, 10);

      const teamInputs = Array.from(teamsList.querySelectorAll<HTMLInputElement>('input[type=text]'));
      const teams: Team[] = teamInputs.map((inp, i) => ({
        name:   inp.value.trim() || `Team ${i + 1}`,
        score:  0,
        rounds: 0,
      }));

      if (teams.length < 2) { show('teams-error'); return null; }
      hide('teams-error');

      if (!langs.length) langs.push('en');

      const customWords = ($('custom-words') as HTMLTextAreaElement).value
        .split(',')
        .map(w => w.trim())
        .filter(Boolean);

      return { langs, cats, diffs, timePerRound, roundsPerTeam, teams, customWords };
    }

    // ── Start game ─────────────────────────────────────────────────────────
    $('btn-start').addEventListener('click', async () => {
      const cfg = readConfig();
      if (!cfg) return;

      ($('btn-start') as HTMLButtonElement).disabled = true;
      $('btn-start').textContent = '⏳ Loading prompts…';

      try {
        const base = await loadPrompts();
        const q    = buildQueue(cfg, base);

        if (q.length === 0) {
          show('pool-warning');
          return;
        }
        hide('pool-warning');

        config         = cfg;
        promptQueue    = q;
        currentTeamIdx = 0;

        showTeamReady();
      } finally {
        ($('btn-start') as HTMLButtonElement).disabled = false;
        $('btn-start').textContent = '🎭 Start Game';
      }
    });

    // ── Team ready screen ──────────────────────────────────────────────────
    function showTeamReady() {
      const team = config.teams[currentTeamIdx];
      $('ready-team-name').textContent  = team.name;
      $('ready-round-info').textContent =
        `Round ${team.rounds + 1} of ${config.roundsPerTeam} · ${promptQueue.length} prompts left`;
      renderScoresTable('ready-scores', -1);
      showScreen('team-ready');
    }

    $('btn-ready-start').addEventListener('click', startRound);

    // ── Round logic ────────────────────────────────────────────────────────
    function startRound() {
      roundScore = 0;
      roundSkips = 0;
      isPaused   = false;
      $('btn-pause').textContent = '⏸ Pause';

      const team = config.teams[currentTeamIdx];
      $('play-team-name').textContent = team.name;
      updateRoundPts();
      showScreen('playing');

      nextPrompt();
      startTimer(config.timePerRound);
    }

    function nextPrompt() {
      if (promptQueue.length === 0) {
        endRound();
        return;
      }
      const p = promptQueue.shift()!;
      $('prompt-cat').textContent  = catLabel(p.category);
      $('prompt-text').textContent = p.text;

      const diffEl = $('prompt-diff');
      diffEl.className = `prompt-diff diff-${p.difficulty}`;
      diffEl.textContent = p.difficulty.charAt(0).toUpperCase() + p.difficulty.slice(1);

      // Flash animation
      const card = $('prompt-card');
      card.style.transition = 'none';
      card.style.opacity    = '0';
      requestAnimationFrame(() => {
        card.style.transition = 'opacity 0.2s';
        card.style.opacity    = '1';
      });
    }

    function updateRoundPts() {
      $('play-round-pts').textContent = `${roundScore} point${roundScore !== 1 ? 's' : ''} this round`;
    }

    $('btn-got-it').addEventListener('click', () => {
      if (isPaused) return;
      roundScore++;
      updateRoundPts();
      nextPrompt();
    });

    $('btn-skip').addEventListener('click', () => {
      if (isPaused) return;
      roundSkips++;
      nextPrompt();
    });

    $('btn-pause').addEventListener('click', togglePause);

    function togglePause() {
      if (isPaused) {
        // Resume
        timerEndTime = Date.now() + timeRemaining * 1000;
        isPaused = false;
        $('btn-pause').textContent = '⏸ Pause';
        $('prompt-text').classList.remove('hidden');
        $('prompt-cat').classList.remove('hidden');
        $('btn-got-it').disabled = false;
        $('btn-skip').disabled   = false;
      } else {
        // Pause
        timeRemaining = Math.ceil((timerEndTime - Date.now()) / 1000);
        isPaused = true;
        $('btn-pause').textContent = '▶ Resume';
        $('prompt-text').classList.add('hidden');
        $('prompt-cat').classList.add('hidden');
        $('btn-got-it').disabled = true;
        $('btn-skip').disabled   = true;
      }
    }

    // ── Timer ──────────────────────────────────────────────────────────────
    const ringFill = $('ring-fill') as unknown as SVGCircleElement;
    const timerRingEl = $('timer-ring');

    function startTimer(seconds: number) {
      timeRemaining = seconds;
      timerEndTime  = Date.now() + seconds * 1000;
      updateTimerDisplay(seconds, seconds);

      if (timerInterval) clearInterval(timerInterval);
      timerInterval = window.setInterval(() => {
        if (isPaused) return;
        const rem = Math.ceil((timerEndTime - Date.now()) / 1000);
        if (rem <= 0) {
          clearInterval(timerInterval!);
          timerInterval = null;
          updateTimerDisplay(0, seconds);
          endRound();
        } else {
          timeRemaining = rem;
          updateTimerDisplay(rem, seconds);
        }
      }, 200);
    }

    function stopTimer() {
      if (timerInterval) { clearInterval(timerInterval); timerInterval = null; }
    }

    function updateTimerDisplay(rem: number, total: number) {
      $('timer-text').textContent = String(rem);
      const pct    = rem / total;
      const offset = CIRCUMFERENCE * (1 - pct);
      ringFill.style.strokeDashoffset = String(offset);

      const urgent = rem <= 10;
      timerRingEl.classList.toggle('urgent', urgent);
      if (urgent && 'vibrate' in navigator) navigator.vibrate(50);
    }

    // ── End round ──────────────────────────────────────────────────────────
    function endRound() {
      stopTimer();
      const team = config.teams[currentTeamIdx];
      team.score  += roundScore;
      team.rounds += 1;

      $('round-end-title').textContent  = promptQueue.length === 0 ? 'Prompts exhausted!' : "Time's up!";
      $('round-end-team').textContent   = team.name;
      $('round-end-pts').textContent    = String(roundScore);
      $('round-end-skips').textContent  = roundSkips > 0 ? `${roundSkips} skip${roundSkips !== 1 ? 's' : ''}` : '';

      renderScoresTable('round-end-scores', currentTeamIdx);
      showScreen('round-end');
    }

    $('btn-next-team').addEventListener('click', () => {
      // Check if game over
      const allDone = config.teams.every(t => t.rounds >= config.roundsPerTeam);
      const poolEmpty = promptQueue.length === 0;

      if (allDone || poolEmpty) {
        showGameOver();
        return;
      }

      // Advance to next team that still has rounds left
      let next = (currentTeamIdx + 1) % config.teams.length;
      while (config.teams[next].rounds >= config.roundsPerTeam) {
        next = (next + 1) % config.teams.length;
      }
      currentTeamIdx = next;
      showTeamReady();
    });

    // ── Scoreboard rendering ───────────────────────────────────────────────
    function renderScoresTable(tableId: string, highlightIdx: number) {
      const sorted = [...config.teams]
        .map((t, i) => ({ ...t, origIdx: i }))
        .sort((a, b) => b.score - a.score);

      const table = $(tableId);
      table.innerHTML = sorted.map(t => `
        <tr class="${t.origIdx === highlightIdx ? 'current-team' : ''}">
          <td class="score-name">${escHtml(t.name)}</td>
          <td class="score-pts">${t.score} pt${t.score !== 1 ? 's' : ''}</td>
        </tr>
      `).join('');
    }

    // ── Game over ──────────────────────────────────────────────────────────
    function showGameOver() {
      const sorted = [...config.teams].sort((a, b) => b.score - a.score);
      const winner = sorted[0];
      const tied   = sorted.filter(t => t.score === winner.score).length > 1;

      $('winner-text').textContent = tied
        ? `It's a tie! 🤝`
        : `${winner.name} wins! 🎉`;

      const medals = ['🥇', '🥈', '🥉'];
      const ranks  = ['first', 'second', 'third'];

      $('podium').innerHTML = sorted.map((t, i) => `
        <div class="podium-row ${ranks[i] ?? ''}">
          <div class="podium-rank">${medals[i] ?? `${i + 1}.`}</div>
          <div class="podium-name">${escHtml(t.name)}</div>
          <div class="podium-score">${t.score} pts</div>
        </div>
      `).join('');

      showScreen('game-over');
    }

    $('btn-play-again').addEventListener('click', () => {
      // Reset scores, keep settings
      config.teams.forEach(t => { t.score = 0; t.rounds = 0; });
      promptQueue    = buildQueue(config, allPrompts);
      currentTeamIdx = 0;
      showTeamReady();
    });

    $('btn-change-setup').addEventListener('click', () => showScreen('setup'));

    // ── Utility ────────────────────────────────────────────────────────────
    function escHtml(s: string): string {
      return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    // ── Init ───────────────────────────────────────────────────────────────
    showScreen('setup');
    // Pre-load prompts in the background for faster start
    loadPrompts().catch(() => {});
  </script>

</body>
</html>
