---
import '../../../styles/games.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no" />
  <title>Charades — The Lions Alliance</title>

  <style>
    /* ── Chip toggles ───────────────────────────────────────────────────── */
    .chip-group { display: flex; flex-wrap: wrap; gap: 0.4rem; }

    .chip {
      padding: 0.4rem 0.9rem;
      border-radius: 999px;
      border: 1.5px solid var(--g-border);
      background: var(--g-bg);
      color: var(--g-muted);
      font-size: 0.82rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.12s;
      user-select: none;
      white-space: nowrap;
    }
    .chip.on      { border-color: var(--g-accent);  background: rgba(233,69,96,0.15);   color: var(--g-text);   }
    .chip.lang-on { border-color: #5882ff;           background: rgba(88,130,255,0.15);  color: #a0b4ff;         }

    /* ── Setup card ─────────────────────────────────────────────────────── */
    .setup-block {
      background: var(--g-surface);
      border: 1px solid var(--g-border);
      border-radius: var(--g-radius);
      padding: 0.9rem 1rem;
      width: 100%;
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
    }

    .setup-block summary {
      cursor: pointer;
      list-style: none;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.5rem;
    }
    .setup-block summary::-webkit-details-marker { display: none; }
    .setup-block summary::after { content: '›'; color: var(--g-muted); transition: transform 0.2s; font-size: 1.2rem; }
    .setup-block[open] summary::after { transform: rotate(90deg); }

    /* ── Custom prompt manager ──────────────────────────────────────────── */
    .custom-add-row {
      display: flex;
      gap: 0.4rem;
      flex-wrap: wrap;
    }

    .custom-add-row input[type="text"] {
      flex: 1;
      min-width: 130px;
      padding: 0.45rem 0.7rem;
      background: var(--g-bg);
      border: 1px solid var(--g-border);
      border-radius: var(--g-radius-sm);
      color: var(--g-text);
      font-size: 0.88rem;
    }
    .custom-add-row input:focus { outline: none; border-color: var(--g-accent); }

    .mini-select {
      padding: 0.45rem 0.5rem;
      background: var(--g-bg);
      border: 1px solid var(--g-border);
      border-radius: var(--g-radius-sm);
      color: var(--g-muted);
      font-size: 0.8rem;
      cursor: pointer;
    }

    .cp-item {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.35rem 0.6rem;
      background: var(--g-bg);
      border: 1px solid var(--g-border);
      border-radius: var(--g-radius-sm);
      font-size: 0.82rem;
    }
    .cp-item .cp-text  { flex: 1; color: var(--g-text); }
    .cp-item .cp-badge { font-size: 0.68rem; color: var(--g-muted); white-space: nowrap; }
    .cp-item .cp-del   { background: none; border: none; color: var(--g-muted); cursor: pointer; font-size: 1rem; line-height: 1; padding: 0 2px; }
    .cp-item .cp-del:hover { color: var(--g-accent); }

    /* ── Prompt browser modal ───────────────────────────────────────────── */
    #modal-browse {
      position: fixed; inset: 0;
      background: rgba(0,0,0,0.82);
      z-index: 200;
      display: flex;
      align-items: flex-start;
      justify-content: center;
      padding: 1rem;
      overflow-y: auto;
    }

    .browse-inner {
      background: var(--g-surface);
      border: 1px solid var(--g-border);
      border-radius: var(--g-radius);
      width: 100%;
      max-width: 480px;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      padding: 1rem;
      margin: auto;
    }

    .pb-item {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.4rem 0.6rem;
      border-radius: var(--g-radius-sm);
      background: var(--g-bg);
      font-size: 0.82rem;
    }
    .pb-item .pb-text  { flex: 1; color: var(--g-text); }
    .pb-item .pb-cat   { font-size: 0.7rem; color: var(--g-muted); }
    .pb-item .pb-diff  { font-size: 0.66rem; border-radius: 999px; padding: 1px 6px; }
    .diff-easy   { background:rgba(29,185,84,.2);  color:var(--g-green);   }
    .diff-medium { background:rgba(245,166,35,.2); color:var(--g-accent2); }
    .diff-hard   { background:rgba(233,69,96,.2);  color:var(--g-accent);  }

    /* ── Play screen ────────────────────────────────────────────────────── */
    .timer-bar-wrap {
      width: 100%; height: 4px;
      background: var(--g-border);
      border-radius: 2px; overflow: hidden;
    }
    .timer-bar-fill {
      height: 100%; background: var(--g-green);
      border-radius: 2px; transition: width 0.2s linear, background 0.3s;
    }
    .timer-bar-fill.urgent { background: var(--g-accent); }

    .prompt-card {
      background: var(--g-surface);
      border: 2px solid var(--g-border);
      border-radius: var(--g-radius);
      padding: 2rem 1.5rem;
      width: 100%;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
      min-height: 200px;
      justify-content: center;
      position: relative;
      transition: border-color 0.2s, opacity 0.18s;
    }
    .prompt-card.hidden-card { border-color: var(--g-surface2); background: var(--g-bg); }

    .cat-label    { font-size:0.75rem; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; color:var(--g-muted); }
    .prompt-text  { font-size:clamp(1.5rem,6vw,2.2rem); font-weight:800; line-height:1.2; color:var(--g-text); }
    .diff-badge   { font-size:0.7rem; border-radius:999px; padding:2px 10px; }

    .hidden-overlay {
      position: absolute; inset: 0;
      background: var(--g-bg);
      border-radius: calc(var(--g-radius) - 2px);
      display: flex; align-items: center; justify-content: center;
      flex-direction: column; gap: 0.5rem;
      color: var(--g-muted); font-size:0.9rem; font-weight:600;
    }

    .play-action-row { display: flex; gap: 0.75rem; width: 100%; }
    .btn-hide { flex:1; background:var(--g-surface2); border:1px solid var(--g-border); color:var(--g-text); }
    .btn-next { flex:2; background:var(--g-accent); color:white; font-size:1.1rem; }

    .progress-info { font-size:0.78rem; color:var(--g-muted); text-align:center; }
  </style>
</head>

<body class="game-page">

  <header class="game-header">
    <a href="/games/" class="brand">🦁 Games</a>
    <button id="btn-browse" class="g-btn secondary small" style="width:auto;">📋 Prompts</button>
  </header>


  <!-- ══ BROWSE PROMPTS MODAL ══════════════════════════════════════════════ -->
  <div id="modal-browse" class="hidden">
    <div class="browse-inner">
      <div style="display:flex;justify-content:space-between;align-items:center;">
        <strong>📋 All Prompts</strong>
        <button id="btn-close-browse" class="g-btn secondary small" style="width:auto;">✕ Close</button>
      </div>

      <!-- Filters -->
      <div style="display:flex;gap:0.4rem;flex-wrap:wrap;">
        <select id="bf-cat"  class="mini-select" style="flex:1;">
          <option value="">All categories</option>
          <option value="movies">🎬 Movies</option>
          <option value="books">📚 Books</option>
          <option value="artists">🎤 Artists</option>
          <option value="songs">🎵 Songs</option>
          <option value="places">🌍 Places</option>
          <option value="sayings">💬 Sayings</option>
          <option value="custom">⭐ Custom</option>
        </select>
        <select id="bf-diff" class="mini-select">
          <option value="">All difficulties</option>
          <option value="easy">🟢 Easy</option>
          <option value="medium">🟡 Medium</option>
          <option value="hard">🔴 Hard</option>
        </select>
        <select id="bf-lang" class="mini-select">
          <option value="">All languages</option>
          <option value="en">🇬🇧 EN</option>
          <option value="nl">🇳🇱 NL</option>
          <option value="any">Both</option>
        </select>
      </div>

      <div id="browse-count" class="progress-info"></div>
      <div id="prompt-browser-list" style="display:flex;flex-direction:column;gap:0.3rem;max-height:60vh;overflow-y:auto;"></div>
    </div>
  </div>


  <!-- ══ SETUP ════════════════════════════════════════════════════════════ -->
  <div id="screen-setup" class="game-content" style="gap:0.85rem;">

    <div style="text-align:center;">
      <div style="font-size:2rem;font-weight:900;background:linear-gradient(135deg,var(--g-accent),var(--g-accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;letter-spacing:-1px;">CHARADES</div>
      <p class="g-subtitle">Act it out — no talking!</p>
    </div>

    <!-- Language -->
    <div class="setup-block">
      <div class="g-label">Language / Taal</div>
      <div class="chip-group" id="lang-chips">
        <div class="chip lang-on" data-lang="en">🇬🇧 English</div>
        <div class="chip lang-on" data-lang="nl">🇳🇱 Nederlands</div>
      </div>
    </div>

    <!-- Categories -->
    <div class="setup-block">
      <div class="g-label">Categories / Categorieën</div>
      <div class="chip-group" id="cat-chips">
        <div class="chip on" data-cat="movies">🎬 Movies</div>
        <div class="chip on" data-cat="books">📚 Books</div>
        <div class="chip on" data-cat="artists">🎤 Artists</div>
        <div class="chip on" data-cat="songs">🎵 Songs</div>
        <div class="chip on" data-cat="places">🌍 Places</div>
        <div class="chip on" data-cat="sayings">💬 Sayings</div>
        <div class="chip on" data-cat="custom">⭐ Custom</div>
      </div>
    </div>

    <!-- Difficulty -->
    <div class="setup-block">
      <div class="g-label">Difficulty / Moeilijkheidsgraad</div>
      <div class="chip-group" id="diff-chips">
        <div class="chip on" data-diff="easy">🟢 Easy</div>
        <div class="chip on" data-diff="medium">🟡 Medium</div>
        <div class="chip on" data-diff="hard">🔴 Hard</div>
      </div>
    </div>

    <!-- Timer (visual only — never auto-advances) -->
    <div class="setup-block">
      <div class="g-label">Timer — visual only, never skips the card</div>
      <div class="chip-group" id="timer-chips">
        <div class="chip on" data-timer="0">⏱ Off</div>
        <div class="chip"    data-timer="30">30s</div>
        <div class="chip"    data-timer="60">60s</div>
        <div class="chip"    data-timer="90">90s</div>
        <div class="chip"    data-timer="120">120s</div>
      </div>
    </div>

    <!-- My Custom Prompts (permanently saved in localStorage) -->
    <details class="setup-block" id="custom-section">
      <summary>
        <span class="g-label" style="font-size:0.85rem;">
          ⭐ My Custom Prompts
          <span id="custom-count-badge" style="color:var(--g-accent2);font-weight:700;"></span>
        </span>
      </summary>

      <p style="font-size:0.78rem;color:var(--g-muted);line-height:1.5;">
        Saved permanently on this device. Included in every future game when the ⭐ Custom category is enabled.
      </p>

      <!-- Add single -->
      <div class="custom-add-row">
        <input type="text" id="cp-text" placeholder="Word or phrase…" maxlength="120" />
        <select id="cp-cat" class="mini-select">
          <option value="custom">⭐ Custom</option>
          <option value="movies">🎬 Movie</option>
          <option value="books">📚 Book</option>
          <option value="artists">🎤 Artist</option>
          <option value="songs">🎵 Song</option>
          <option value="places">🌍 Place</option>
          <option value="sayings">💬 Saying</option>
        </select>
        <select id="cp-diff" class="mini-select">
          <option value="easy">Easy</option>
          <option value="medium">Medium</option>
          <option value="hard">Hard</option>
        </select>
        <select id="cp-lang" class="mini-select">
          <option value="any">Both</option>
          <option value="en">🇬🇧 EN</option>
          <option value="nl">🇳🇱 NL</option>
        </select>
        <button id="btn-cp-add" class="g-btn green small" style="flex-shrink:0;">+ Add</button>
      </div>

      <!-- Bulk import -->
      <details style="margin-top:0.1rem;">
        <summary style="font-size:0.78rem;color:var(--g-muted);cursor:pointer;list-style:none;">▸ Bulk add (comma-separated)</summary>
        <div style="display:flex;flex-direction:column;gap:0.4rem;margin-top:0.4rem;">
          <textarea id="cp-bulk" rows="2"
            placeholder="Uncle Bob dancing, The family dog, Christmas dinner…"
            style="width:100%;padding:0.5rem;background:var(--g-bg);border:1px solid var(--g-border);border-radius:var(--g-radius-sm);color:var(--g-text);font-size:0.82rem;resize:vertical;font-family:inherit;"></textarea>
          <button id="btn-cp-bulk" class="g-btn secondary small" style="align-self:flex-start;">Import as Custom · Easy · Both languages</button>
        </div>
      </details>

      <!-- List -->
      <div id="custom-prompt-list" style="display:flex;flex-direction:column;gap:0.3rem;max-height:260px;overflow-y:auto;"></div>
      <div id="cp-empty" style="font-size:0.8rem;color:var(--g-muted);text-align:center;padding:0.4rem 0;">No custom prompts yet.</div>

      <!-- Actions -->
      <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-top:0.2rem;">
        <button id="btn-cp-export" class="g-btn secondary small">📋 Copy all to clipboard</button>
        <button id="btn-cp-clear"  class="g-btn secondary small" style="color:var(--g-accent);">🗑 Clear all</button>
      </div>
    </details>

    <!-- Pool count -->
    <div id="pool-info" class="g-alert info" style="font-size:0.82rem;"></div>
    <div id="pool-warn" class="g-alert error hidden">No prompts match your filters. Enable more categories or difficulties.</div>

    <button id="btn-start" class="g-btn primary" style="font-size:1.1rem;padding:1.1rem;">
      🎭 Start Game
    </button>

  </div><!-- /screen-setup -->


  <!-- ══ PLAY ══════════════════════════════════════════════════════════════ -->
  <div id="screen-play" class="game-content hidden" style="gap:1rem;">

    <!-- Timer bar -->
    <div id="timer-bar-wrap" class="timer-bar-wrap hidden">
      <div id="timer-bar-fill" class="timer-bar-fill" style="width:100%;"></div>
    </div>

    <!-- Prompt card -->
    <div class="prompt-card" id="prompt-card">
      <div class="cat-label"   id="play-cat">🎬 Movie</div>
      <div class="prompt-text" id="play-text">Loading…</div>
      <div class="diff-badge"  id="play-diff"></div>

      <!-- Hidden overlay -->
      <div class="hidden-overlay hidden" id="hidden-overlay">
        <span style="font-size:2.5rem;">🙈</span>
        <span>Card hidden</span>
        <span style="font-size:0.75rem;font-weight:400;">Tap "Show" to reveal</span>
      </div>
    </div>

    <!-- Buttons -->
    <div class="play-action-row">
      <button class="g-btn btn-hide" id="btn-hide">🙈 Hide</button>
      <button class="g-btn btn-next" id="btn-next">Next →</button>
    </div>

    <!-- Progress -->
    <div class="progress-info" id="play-progress"></div>

    <button id="btn-back-setup" class="g-btn secondary" style="font-size:0.85rem;padding:0.55rem;">
      ⚙ Back to Setup
    </button>

  </div><!-- /screen-play -->


  <!-- ══ ALL DONE ═══════════════════════════════════════════════════════════ -->
  <div id="screen-done" class="game-content hidden" style="gap:1.25rem;">
    <div style="text-align:center;">
      <div style="font-size:2.5rem;">🎉</div>
      <div style="font-weight:800;font-size:1.3rem;margin-top:0.25rem;">All cards done!</div>
      <p class="g-subtitle">You've gone through every prompt.</p>
    </div>
    <button id="btn-reshuffle"  class="g-btn green"    style="font-size:1.05rem;">↺ Shuffle &amp; Play Again</button>
    <button id="btn-done-setup" class="g-btn secondary" style="font-size:0.9rem;">⚙ Change Settings</button>
  </div>


  <!-- ══ SCRIPTS ══════════════════════════════════════════════════════════ -->
  <script>
    // ── Types ──────────────────────────────────────────────────────────────
    interface Prompt {
      id:         number | string;
      text:       string;
      category:   string;
      difficulty: string;
      lang:       string;
    }

    // ── Constants ──────────────────────────────────────────────────────────
    const LS_KEY = 'charades_custom_prompts';

    const CAT_META: Record<string, { icon: string; label: string }> = {
      movies:  { icon: '🎬', label: 'Movie'   },
      books:   { icon: '📚', label: 'Book'    },
      artists: { icon: '🎤', label: 'Artist'  },
      songs:   { icon: '🎵', label: 'Song'    },
      places:  { icon: '🌍', label: 'Place'   },
      sayings: { icon: '💬', label: 'Saying'  },
      custom:  { icon: '⭐', label: 'Custom'  },
    };

    // ── DOM helpers ────────────────────────────────────────────────────────
    const $ = (id: string) => document.getElementById(id)!;
    const show = (...ids: string[]) => ids.forEach(id => $(id).classList.remove('hidden'));
    const hide = (...ids: string[]) => ids.forEach(id => $(id).classList.add('hidden'));

    function showScreen(s: 'setup' | 'play' | 'done') {
      ['setup','play','done'].forEach(sc => hide(`screen-${sc}`));
      show(`screen-${s}`);
    }

    function catLabel(cat: string) {
      const m = CAT_META[cat];
      return m ? `${m.icon} ${m.label}` : cat;
    }

    function escHtml(s: string) {
      return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    function activeData(groupId: string, attr: string): string[] {
      return Array.from(
        document.querySelectorAll<HTMLElement>(`#${groupId} .chip.on, #${groupId} .chip.lang-on`)
      ).map(c => c.dataset[attr]!).filter(Boolean);
    }

    // ── Chip wire-up ───────────────────────────────────────────────────────
    document.querySelectorAll<HTMLElement>('#lang-chips .chip').forEach(c =>
      c.addEventListener('click', () => { c.classList.toggle('lang-on'); updatePoolInfo(); })
    );
    document.querySelectorAll<HTMLElement>('#cat-chips  .chip').forEach(c =>
      c.addEventListener('click', () => { c.classList.toggle('on');      updatePoolInfo(); })
    );
    document.querySelectorAll<HTMLElement>('#diff-chips .chip').forEach(c =>
      c.addEventListener('click', () => { c.classList.toggle('on');      updatePoolInfo(); })
    );
    // timer chips: single-select
    document.querySelectorAll<HTMLElement>('#timer-chips .chip').forEach(c =>
      c.addEventListener('click', () => {
        document.querySelectorAll<HTMLElement>('#timer-chips .chip').forEach(x => x.classList.remove('on'));
        c.classList.add('on');
      })
    );

    // ── localStorage prompts ───────────────────────────────────────────────
    function loadCustom(): Prompt[] {
      try { return JSON.parse(localStorage.getItem(LS_KEY) ?? '[]'); }
      catch { return []; }
    }

    function saveCustom(list: Prompt[]) {
      localStorage.setItem(LS_KEY, JSON.stringify(list));
    }

    let customPrompts: Prompt[] = loadCustom();

    function renderCustomList() {
      const list = $('custom-prompt-list');
      list.innerHTML = '';

      if (customPrompts.length === 0) {
        show('cp-empty');
      } else {
        hide('cp-empty');
        customPrompts.forEach((p, i) => {
          const el = document.createElement('div');
          el.className = 'cp-item';
          el.innerHTML = `
            <span class="cp-text">${escHtml(p.text)}</span>
            <span class="cp-badge">${catLabel(p.category)} · ${p.difficulty} · ${p.lang}</span>
            <button class="cp-del" data-i="${i}" title="Remove">×</button>
          `;
          el.querySelector<HTMLButtonElement>('.cp-del')!.addEventListener('click', () => {
            customPrompts.splice(i, 1);
            saveCustom(customPrompts);
            renderCustomList();
            updatePoolInfo();
          });
          list.appendChild(el);
        });
      }

      $('custom-count-badge').textContent = customPrompts.length > 0 ? `(${customPrompts.length})` : '';
    }

    function addCustom(text: string, cat: string, diff: string, lang: string) {
      const t = text.trim();
      if (!t) return;
      customPrompts.push({ id: `cp_${Date.now()}_${Math.random()}`, text: t, category: cat, difficulty: diff, lang });
      saveCustom(customPrompts);
      renderCustomList();
      updatePoolInfo();
    }

    $('btn-cp-add').addEventListener('click', () => {
      const inp = $('cp-text') as HTMLInputElement;
      addCustom(
        inp.value,
        ($('cp-cat')  as HTMLSelectElement).value,
        ($('cp-diff') as HTMLSelectElement).value,
        ($('cp-lang') as HTMLSelectElement).value,
      );
      inp.value = '';
      inp.focus();
    });

    ($('cp-text') as HTMLInputElement).addEventListener('keydown', e => {
      if (e.key === 'Enter') $('btn-cp-add').click();
    });

    $('btn-cp-bulk').addEventListener('click', () => {
      const raw = ($('cp-bulk') as HTMLTextAreaElement).value;
      raw.split(',').map(w => w.trim()).filter(Boolean).forEach(w => addCustom(w, 'custom', 'easy', 'any'));
      ($('cp-bulk') as HTMLTextAreaElement).value = '';
    });

    $('btn-cp-export').addEventListener('click', async () => {
      const text = customPrompts.map(p => p.text).join(', ');
      try {
        await navigator.clipboard.writeText(text);
        $('btn-cp-export').textContent = '✅ Copied!';
        setTimeout(() => { $('btn-cp-export').textContent = '📋 Copy all to clipboard'; }, 2000);
      } catch { prompt('Copy these:', text); }
    });

    $('btn-cp-clear').addEventListener('click', () => {
      if (!confirm(`Delete all ${customPrompts.length} custom prompt(s)?`)) return;
      customPrompts = [];
      saveCustom(customPrompts);
      renderCustomList();
      updatePoolInfo();
    });

    // ── Built-in prompts ───────────────────────────────────────────────────
    let builtIn: Prompt[] = [];

    async function loadBuiltIn(): Promise<Prompt[]> {
      if (builtIn.length) return builtIn;
      const res = await fetch('/charades/prompts.json');
      builtIn = await res.json();
      return builtIn;
    }

    // ── Pool info ──────────────────────────────────────────────────────────
    async function updatePoolInfo() {
      const base  = await loadBuiltIn().catch(() => [] as Prompt[]);
      const langs = activeData('lang-chips', 'lang');
      const cats  = activeData('cat-chips',  'cat');
      const diffs = activeData('diff-chips', 'diff');

      const count = [...base, ...customPrompts].filter(p =>
        (p.lang === 'any' || langs.includes(p.lang)) &&
        cats.includes(p.category) &&
        diffs.includes(p.difficulty)
      ).length;

      $('pool-info').textContent = `${count} prompt${count !== 1 ? 's' : ''} match your current filters.`;
      count > 0 ? hide('pool-warn') : show('pool-warn');
    }

    // ── Browse modal ───────────────────────────────────────────────────────
    async function renderBrowser() {
      const base     = await loadBuiltIn().catch(() => [] as Prompt[]);
      const all      = [...base, ...customPrompts];
      const cat      = ($('bf-cat')  as HTMLSelectElement).value;
      const diff     = ($('bf-diff') as HTMLSelectElement).value;
      const lang     = ($('bf-lang') as HTMLSelectElement).value;
      const filtered = all.filter(p =>
        (!cat  || p.category   === cat)  &&
        (!diff || p.difficulty === diff) &&
        (!lang || p.lang       === lang)
      );

      $('browse-count').textContent = `Showing ${filtered.length} of ${all.length} prompts`;
      $('prompt-browser-list').innerHTML = filtered.map(p => `
        <div class="pb-item">
          <span class="pb-text">${escHtml(p.text)}</span>
          <span class="pb-cat">${catLabel(p.category)}</span>
          <span class="pb-diff diff-${p.difficulty}">${p.difficulty}</span>
        </div>
      `).join('');
    }

    $('btn-browse').addEventListener('click', async () => {
      $('modal-browse').style.display = 'flex';
      await renderBrowser();
    });
    $('btn-close-browse').addEventListener('click', () => { $('modal-browse').style.display = 'none'; });
    $('modal-browse').addEventListener('click', e => {
      if (e.target === $('modal-browse')) $('modal-browse').style.display = 'none';
    });
    ['bf-cat','bf-diff','bf-lang'].forEach(id => $(id).addEventListener('change', renderBrowser));

    // ── Game state ─────────────────────────────────────────────────────────
    let queue:         Prompt[] = [];
    let totalInQueue   = 0;
    let cardHidden     = false;
    let timerSecs      = 0;
    let timerEndTime   = 0;
    let timerInterval: number | null = null;

    function shuffle<T>(a: T[]): T[] {
      const arr = [...a];
      for (let i = arr.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [arr[i], arr[j]] = [arr[j], arr[i]];
      }
      return arr;
    }

    function buildQueue(): Prompt[] {
      const langs = activeData('lang-chips', 'lang');
      const cats  = activeData('cat-chips',  'cat');
      const diffs = activeData('diff-chips', 'diff');
      return shuffle([...builtIn, ...customPrompts].filter(p =>
        (p.lang === 'any' || langs.includes(p.lang)) &&
        cats.includes(p.category) &&
        diffs.includes(p.difficulty)
      ));
    }

    // ── Start ──────────────────────────────────────────────────────────────
    $('btn-start').addEventListener('click', async () => {
      ($('btn-start') as HTMLButtonElement).disabled = true;
      $('btn-start').textContent = '⏳ Loading…';
      try {
        await loadBuiltIn();
        const q = buildQueue();
        if (q.length === 0) { show('pool-warn'); return; }
        hide('pool-warn');

        queue        = q;
        totalInQueue = q.length;
        timerSecs    = parseInt(
          document.querySelector<HTMLElement>('#timer-chips .chip.on')?.dataset.timer ?? '0', 10
        );

        showScreen('play');
        displayCard();
      } finally {
        ($('btn-start') as HTMLButtonElement).disabled = false;
        $('btn-start').textContent = '🎭 Start Game';
      }
    });

    // ── Display card ───────────────────────────────────────────────────────
    function displayCard() {
      cardHidden = false;
      hide('hidden-overlay');
      $('prompt-card').classList.remove('hidden-card');
      $('btn-hide').textContent = '🙈 Hide';

      if (queue.length === 0) { stopTimer(); showScreen('done'); return; }

      const p = queue[0];
      $('play-cat').textContent  = catLabel(p.category);
      $('play-text').textContent = p.text;
      const diff = $('play-diff');
      diff.className = `diff-badge diff-${p.difficulty}`;
      diff.textContent = p.difficulty.charAt(0).toUpperCase() + p.difficulty.slice(1);

      const done = totalInQueue - queue.length;
      $('play-progress').textContent = `Card ${done + 1} of ${totalInQueue}`;

      // Fade in
      const card = $('prompt-card') as HTMLElement;
      card.style.opacity = '0';
      requestAnimationFrame(() => { card.style.opacity = '1'; });

      // Timer
      if (timerSecs > 0) { show('timer-bar-wrap'); startTimer(timerSecs); }
      else                { hide('timer-bar-wrap'); stopTimer(); }
    }

    // ── Hide / Show ────────────────────────────────────────────────────────
    $('btn-hide').addEventListener('click', () => {
      cardHidden = !cardHidden;
      if (cardHidden) {
        show('hidden-overlay');
        $('prompt-card').classList.add('hidden-card');
        $('btn-hide').textContent = '👁 Show';
        stopTimer();
      } else {
        hide('hidden-overlay');
        $('prompt-card').classList.remove('hidden-card');
        $('btn-hide').textContent = '🙈 Hide';
        if (timerSecs > 0) startTimer(timerSecs);
      }
    });

    // ── Next ───────────────────────────────────────────────────────────────
    $('btn-next').addEventListener('click', () => { queue.shift(); displayCard(); });

    // ── Back / reshuffle ───────────────────────────────────────────────────
    $('btn-back-setup').addEventListener('click', () => { stopTimer(); showScreen('setup'); });
    $('btn-done-setup').addEventListener('click', () => { stopTimer(); showScreen('setup'); });
    $('btn-reshuffle').addEventListener('click', () => {
      queue        = buildQueue();
      totalInQueue = queue.length;
      showScreen('play');
      displayCard();
    });

    // ── Timer ──────────────────────────────────────────────────────────────
    function startTimer(secs: number) {
      stopTimer();
      timerEndTime = Date.now() + secs * 1000;
      updateBar(secs, secs);
      timerInterval = window.setInterval(() => {
        const rem = (timerEndTime - Date.now()) / 1000;
        if (rem <= 0) {
          updateBar(0, secs);
          stopTimer();
          if ('vibrate' in navigator) navigator.vibrate([100, 60, 100]);
        } else {
          updateBar(rem, secs);
        }
      }, 200);
    }

    function stopTimer() {
      if (timerInterval !== null) { clearInterval(timerInterval); timerInterval = null; }
    }

    function updateBar(rem: number, total: number) {
      const fill = $('timer-bar-fill');
      fill.style.width = `${Math.max(0, (rem / total) * 100)}%`;
      fill.classList.toggle('urgent', rem > 0 && rem <= 10);
    }

    // ── Init ───────────────────────────────────────────────────────────────
    renderCustomList();
    loadBuiltIn().then(updatePoolInfo).catch(() => {});
  </script>

</body>
</html>