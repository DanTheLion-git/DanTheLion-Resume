---
// Public homepage — The Lions Alliance — Coming Soon
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>The Lions Alliance</title>
    <meta name="description" content="The Lions Alliance — coming soon." />
    <!-- Apply saved theme before CSS renders — prevents flash of wrong theme -->
    <script>
      (function () {
        var stored = localStorage.getItem('lions-theme');
        var theme  = stored
          ? stored
          : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.className = 'theme-' + theme;
      })();
    </script>
    <link rel="stylesheet" href="/_astro/_slug_.B77jTI1m.css" />
    <style>
      /* ── Coming Soon layout ── */
      .coming-soon-page {
        min-height: calc(100vh - 120px);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 60px 24px;
        gap: 0;
      }

      .cs-badge {
        display: inline-block;
        border: 1px solid var(--border);
        background: color-mix(in srgb, var(--accent-green-light) 10%, var(--card-bg));
        color: var(--accent-green-light);
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        padding: 5px 16px;
        border-radius: 999px;
        margin-bottom: 28px;
      }

      .cs-heading {
        font-size: clamp(2rem, 6vw, 3.8rem);
        font-weight: 700;
        line-height: 1.1;
        letter-spacing: -0.5px;
        margin-bottom: 18px;
        color: var(--fg);
      }

      .cs-heading .accent {
        color: var(--accent-green-light);
      }

      .cs-sub {
        font-size: clamp(0.95rem, 2vw, 1.1rem);
        color: var(--fg-muted);
        max-width: 420px;
        line-height: 1.65;
        margin: 0 auto 44px;
      }

      .cs-divider {
        width: 44px;
        height: 3px;
        background: linear-gradient(90deg, var(--accent-green), var(--accent-green-light));
        border-radius: 999px;
        margin: 0 auto 44px;
      }

      /* Nav cards */
      .cs-cards {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        justify-content: center;
        max-width: 680px;
      }

      .cs-card {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 5px;
        padding: 20px 26px;
        min-width: 180px;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        background: var(--card-bg);
        box-shadow: 0 4px 16px rgba(0,0,0,0.06);
        text-decoration: none;
        color: var(--fg);
        transition: transform 0.14s ease, box-shadow 0.14s ease, border-color 0.14s ease;
      }

      .cs-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 28px rgba(0,0,0,0.10);
        border-color: var(--accent-green-light);
        text-decoration: none;
      }

      .cs-card-icon {
        font-size: 1.55rem;
        line-height: 1;
        margin-bottom: 6px;
      }

      .cs-card-label {
        font-size: 0.98rem;
        font-weight: 700;
        color: var(--fg);
      }

      .cs-card-desc {
        font-size: 0.83rem;
        color: var(--fg-muted);
      }

      @media (max-width: 480px) {
        .cs-card { min-width: 100%; }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a href="/" class="logo">The Lions Alliance</a>
        <nav class="nav">
          <a href="/resume/">Resume</a>
          <a href="/games/">Games</a>
          <button id="theme-toggle" class="theme-toggle" aria-label="Toggle colour scheme" title="Toggle light / dark mode">
            <svg class="theme-icon theme-icon--sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
              <circle cx="12" cy="12" r="5"></circle>
              <line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
              <line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
            </svg>
            <svg class="theme-icon theme-icon--moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"></path>
            </svg>
          </button>
        </nav>
      </div>
    </header>

    <main class="site-main">
      <div class="coming-soon-page">
        <span class="cs-badge">Launching Soon</span>
        <h1 class="cs-heading">Something is<br><span class="accent">on its way.</span></h1>
        <p class="cs-sub">The Lions Alliance is being built.</p>
        <div class="cs-divider"></div>
      </div>
    </main>

    <footer class="site-footer">
      <div class="container">
        &copy; <span id="yr"></span> The Lions Alliance
      </div>
    </footer>

    <script>
      document.getElementById('yr').textContent = new Date().getFullYear();

      const btn = document.getElementById('theme-toggle');
      if (btn) {
        btn.addEventListener('click', () => {
          const isLight = document.documentElement.classList.contains('theme-light');
          const next = isLight ? 'dark' : 'light';
          document.documentElement.className = 'theme-' + next;
          localStorage.setItem('lions-theme', next);
        });
      }
    </script>
  </body>
</html>